@* Sidebar navigation (Figma: Library page left panel) *@
@inject NavigationManager Nav
@inject AppState AppState
@implements IDisposable

<nav class="flex flex-col bg-background/40 backdrop-blur-xl h-full select-none shrink-0 border-r border-white/[0.04] transition-all duration-300 @(AppState.IsSidebarCollapsed ? "w-16" : "w-60")">
    @* Logo & Toggle *@
    <div class="flex @(AppState.IsSidebarCollapsed ? "flex-col items-center gap-4 py-5" : "items-center justify-between px-6 py-5") transition-all duration-300 border-b border-white/[0.04]">
        <div class="flex items-center gap-3">
            <div class="relative flex items-center justify-center w-8 h-8 rounded-lg bg-gradient-to-tr from-neon-purple to-indigo-500 shadow-lg shadow-neon-purple/20 shrink-0">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 9l10.5-3m0 0L21 9m-1.5-3v13.5m-3-12h3m0 0l-10.5 3m0 0L3 12m6-3v13.5M3 12v6.75A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-15 1.5H1.5M18 10.5h1.5"/>
                </svg>
            </div>
            @if (!AppState.IsSidebarCollapsed)
            {
                <span class="text-base font-bold tracking-wider text-on-surface">MediaMusic</span>
            }
        </div>
        
        <button @onclick="ToggleCollapse" class="p-1.5 rounded-lg hover:bg-white/[0.06] text-on-surface/60 hover:text-on-surface transition-all duration-200 shrink-0" title="@(AppState.IsSidebarCollapsed ? "展开" : "收起")">
            <svg class="w-5 h-5 transition-transform duration-300 @(AppState.IsSidebarCollapsed ? "rotate-180" : "")" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <rect x="3" y="4" width="18" height="16" rx="2.5" stroke-linejoin="round" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 4v16" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 10l-3 2 3 2" />
            </svg>
        </button>
    </div>

    @* Navigation links *@
    <ul class="flex-1 space-y-1.5 mt-4 @(AppState.IsSidebarCollapsed ? "px-2" : "px-4")">
        <SidebarLink Href="/" Icon="home" Label="首页" CurrentUri="@Nav.Uri" />
        <SidebarLink Href="/discover" Icon="discover" Label="发现" CurrentUri="@Nav.Uri" />
        <SidebarLink Href="/library" Icon="library" Label="音乐库" CurrentUri="@Nav.Uri" />
        <SidebarLink Href="/playlists" Icon="playlist" Label="播放列表" CurrentUri="@Nav.Uri" />
        <SidebarLink Href="/eq" Icon="eq" Label="均衡器" CurrentUri="@Nav.Uri" />
        <SidebarLink Href="/settings" Icon="settings" Label="设置" CurrentUri="@Nav.Uri" />
    </ul>
</nav>

@code {
    protected override void OnInitialized()
    {
        AppState.Changed += OnStateChanged;
    }

    private void OnStateChanged(object? sender, EventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private void ToggleCollapse()
    {
        AppState.SetSidebarCollapsed(!AppState.IsSidebarCollapsed);
    }

    public void Dispose()
    {
        AppState.Changed -= OnStateChanged;
    }
}

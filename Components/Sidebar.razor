@* Sidebar navigation (Figma: Library page left panel) *@
@inject NavigationManager Nav

<nav class="flex w-60 flex-col bg-background/40 backdrop-blur-xl h-full select-none shrink-0">
    @* Logo *@
    <div class="flex items-center gap-3 px-6 py-5">
        <div class="relative flex items-center justify-center w-8 h-8 rounded-lg bg-gradient-to-tr from-neon-purple to-indigo-500 shadow-lg shadow-neon-purple/20">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 9l10.5-3m0 0L21 9m-1.5-3v13.5m-3-12h3m0 0l-10.5 3m0 0L3 12m6-3v13.5M3 12v6.75A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-15 1.5H1.5M18 10.5h1.5"/>
            </svg>
        </div>
        <span class="text-base font-bold tracking-wider bg-clip-text text-transparent bg-gradient-to-r from-white to-gray-400">MediaMusic</span>
    </div>

    @* Navigation links *@
    <ul class="flex-1 space-y-1.5 px-4 mt-4">
        <SidebarLink Href="/" Icon="home" Label="首页" CurrentUri="@Nav.Uri" />
        <SidebarLink Href="/discover" Icon="discover" Label="发现" CurrentUri="@Nav.Uri" />
        <SidebarLink Href="/library" Icon="library" Label="音乐库" CurrentUri="@Nav.Uri" />
        <SidebarLink Href="/playlists" Icon="playlist" Label="播放列表" CurrentUri="@Nav.Uri" />
        <SidebarLink Href="/eq" Icon="eq" Label="均衡器" CurrentUri="@Nav.Uri" />
        <SidebarLink Href="/settings" Icon="settings" Label="设置" CurrentUri="@Nav.Uri" />
    </ul>

    @* User profile footer *@
    <div class="flex items-center gap-3 px-6 py-5 bg-white/[0.02] border-t border-white/[0.03]">
        <div class="relative w-9 h-9 rounded-full bg-gradient-to-tr from-neutral-800 to-neutral-700 flex items-center justify-center text-sm shadow-inner ring-1 ring-white/10 shrink-0">
            🎧
            <span class="absolute bottom-0 right-0 w-2.5 h-2.5 rounded-full bg-emerald-500 ring-2 ring-background"></span>
        </div>
        <div class="min-w-0">
            <p class="text-sm font-semibold text-gray-200 truncate">Audiophile User</p>
            <span class="inline-flex items-center text-[9px] font-extrabold tracking-widest px-2 py-0.5 mt-0.5 rounded-full bg-muted-gold/10 text-muted-gold border border-muted-gold/20 uppercase">PREMIUM</span>
        </div>
    </div>
</nav>


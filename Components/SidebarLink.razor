@* Individual sidebar navigation link *@

<li>
    <a href="@Href"
       class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm transition-all duration-300
              @(IsActive ? "bg-gradient-to-r from-neon-purple/15 to-neon-purple/2 text-neon-purple font-semibold shadow-inner" : "text-on-surface/60 hover:bg-white/[0.04] hover:text-on-surface")">
        @switch (Icon)
        {
            case "home":
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
                break;
            case "discover":
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9 9 0 100-18 9 9 0 000 18z"/><path stroke-linecap="round" stroke-linejoin="round" d="M16.24 7.76l-2.12 6.36-6.36 2.12 2.12-6.36 6.36-2.12z"/></svg>
                break;
            case "library":
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.625-12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0h8.25M2.25 15.75v.75A2.25 2.25 0 004.5 18.75h15a2.25 2.25 0 002.25-2.25v-.75m-18 0A2.25 2.25 0 004.5 15h15A2.25 2.25 0 0021.75 15.75m-18 0v-3m18 3v-3M4.5 15V12m15 3V12"/></svg>
                break;
            case "playlist":
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M12 17.25h8.25M3 16.25l3 3m0 0l3-3m-3 3v-6"/></svg>
                break;
            case "eq":
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 13.5V3.75m0 16.5V17.25m6-3.75V3.75m0 16.5V13.5m6-1.5V3.75m0 16.5V9.75M3 13.5h6m3-3h6m-9 6h6"/></svg>
                break;
            case "settings":
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.43l-1.003.828c-.293.241-.438.613-.43.992a7.723 7.723 0 010 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.43l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 010-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                break;
        }
        <span>@Label</span>
    </a>
</li>

@code {
    [Parameter] public string Href { get; set; } = "/";
    [Parameter] public string Icon { get; set; } = "home";
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string CurrentUri { get; set; } = "";

    private bool IsActive => CurrentUri.TrimEnd('/').EndsWith(Href.TrimEnd('/')) ||
                              (Href == "/" && (CurrentUri.EndsWith("/") || CurrentUri.EndsWith("/index")));
}

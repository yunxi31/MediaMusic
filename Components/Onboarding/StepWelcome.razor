@* Step 0 – Welcome screen (Figma: 引导页 - 欢迎 Welcome) *@
<div class="welcome-container relative flex h-full w-full flex-col items-center justify-center px-10 py-16 text-center select-none overflow-hidden">
    @* Ambient glow background *@
    <div class="absolute w-[450px] h-[450px] rounded-full bg-indigo-500/10 blur-[100px] pointer-events-none -translate-y-12"></div>
    <div class="absolute w-[350px] h-[350px] rounded-full bg-accent/10 blur-[80px] pointer-events-none -translate-y-12"></div>

    @* Logo & Sound wave circle *@
    <div class="relative w-24 h-24 rounded-full border border-white/20 flex items-center justify-center bg-black/40 shadow-[0_0_20px_rgba(185,131,255,0.15)] mb-8">
        <svg class="w-10 h-10 text-accent animate-pulse" viewBox="0 0 48 48" fill="currentColor">
            <rect x="10.5" y="18" width="3" height="12" rx="1.5" />
            <rect x="16.5" y="12" width="3" height="24" rx="1.5" />
            <rect x="22.5" y="8"  width="3" height="32" rx="1.5" />
            <rect x="28.5" y="12" width="3" height="24" rx="1.5" />
            <rect x="34.5" y="18" width="3" height="12" rx="1.5" />
        </svg>
    </div>

    @* Title with glow *@
    <div class="relative mb-6">
        <div class="absolute inset-0 bg-[#b983ff]/20 blur-2xl rounded-full scale-125 opacity-70 pointer-events-none"></div>
        <h1 class="relative text-5xl font-extrabold tracking-wide text-white outline-none focus:outline-none" style="text-shadow: 0 0 30px rgba(185, 131, 255, 0.4), 0 0 60px rgba(185, 131, 255, 0.2);">
            MediaMusic
        </h1>
    </div>

    @* Slogans *@
    <div class="space-y-4 mb-16 max-w-md">
        <h2 class="text-2xl font-bold tracking-wider text-white">极纯之声，由此开启</h2>
        <div class="space-y-1">
            <p class="text-sm text-white/60 tracking-wide font-normal">发烧级本地无损音乐播放中心</p>
            <p class="text-xs text-white/30 tracking-widest font-light">(Hi-Res Local Lossless Audio Hub)</p>
        </div>
    </div>

    @* Pill button *@
    <button class="group relative flex items-center justify-center px-12 py-3.5 rounded-full border border-white/10 bg-white/5 text-white/90 font-medium hover:border-accent/40 hover:bg-[#b983ff]/10 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/50 transition-all duration-300 shadow-[0_0_20px_rgba(255,255,255,0.02)] hover:shadow-[0_0_30px_rgba(185,131,255,0.15)]"
            @onclick="OnNext">
        <span class="tracking-widest">开始体验</span>
        <svg class="w-4 h-4 ml-2.5 transition-transform duration-300 transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
        </svg>
    </button>
</div>

<style>
    .welcome-container {
        background: radial-gradient(circle at center, #150f26 0%, #06040a 100%);
    }
</style>

@code {
    [Parameter] public EventCallback OnNext { get; set; }
}

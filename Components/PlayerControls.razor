@inject PlayerService Player
@inject NavigationManager Nav

@* Bottom playback control bar (Figma: library page bottom player) *@
<div class="flex h-[76px] items-center justify-between gap-6 bg-background/60 backdrop-blur-xl border-t border-white/[0.03] px-6 select-none shadow-[0_-8px_32px_rgba(0,0,0,0.4)] relative z-10">

    @* ── Left: Cover thumbnail + song details ── *@
    <div class="flex items-center gap-3 w-72 min-w-0 cursor-pointer group" @onclick="GoToNowPlaying">
        <div class="w-12 h-12 rounded-lg bg-white/[0.02] overflow-hidden shrink-0 shadow-md ring-1 ring-white/10 group-hover:ring-neon-purple/50 transition-all duration-300 relative">
            @if (!string.IsNullOrEmpty(Player.State.CurrentTrack?.CoverPath))
            {
                <img src="@Player.State.CurrentTrack.CoverPath" alt="" class="w-full h-full object-cover" />
            }
            else
            {
                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-neon-purple/20 to-neutral-900">
                    <svg class="w-5 h-5 text-neon-purple/60" fill="currentColor" viewBox="0 0 24 24"><path d="M12 3v10.55A4 4 0 1 0 14 17V7h4V3h-6z"/></svg>
                </div>
            }
        </div>
        <div class="min-w-0 flex-1">
            <p class="text-sm font-semibold text-gray-200 truncate group-hover:text-neon-purple transition-colors duration-300">@(Player.State.CurrentTrack?.Title ?? "未播放")</p>
            <p class="text-xs text-on-surface/40 truncate mt-0.5">@(Player.State.CurrentTrack?.ArtistName ?? "将音频文件拖入即可开始")</p>
        </div>
        @* Favourite button *@
        <button class="text-on-surface/30 hover:text-neon-purple transition-colors ml-2 shrink-0 p-1 rounded-full hover:bg-white/[0.02]" title="收藏">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
            </svg>
        </button>
    </div>

    @* ── Center: Playback controls + timeline ── *@
    <div class="flex-1 flex flex-col items-center gap-1.5 max-w-xl">
        <div class="flex items-center gap-5">
            <button class="text-on-surface/40 hover:text-neon-purple transition-colors p-1" title="随机播放">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.656 48.656 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-10.5 6c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M6 15l-3 3m3-3l3 3"/></svg>
            </button>
            <button class="text-on-surface/50 hover:text-neon-purple transition-colors p-1" title="上一首" @onclick="Prev">
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 16.811c0 .864-.933 1.405-1.683.977l-7.108-4.062a1.125 1.125 0 010-1.953l7.108-4.062A1.125 1.125 0 0121 8.688v8.123zM11.25 16.811c0 .864-.933 1.405-1.683.977l-7.108-4.062a1.125 1.125 0 010-1.953l7.108-4.062a1.125 1.125 0 011.683.977v8.123z"/></svg>
            </button>
            
            @* Floating play button with purple glow *@
            <button class="w-10 h-10 rounded-full bg-gradient-to-tr from-neon-purple to-indigo-500 text-white flex items-center justify-center hover:scale-105 active:scale-95 shadow-[0_0_12px_rgba(168,85,247,0.35)] hover:shadow-[0_0_20px_rgba(168,85,247,0.55)] transition-all duration-300 shrink-0" title="@(Player.State.IsPlaying ? "暂停" : "播放")" @onclick="TogglePlay">
                @if (Player.State.IsPlaying)
                {
                    <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><rect x="5" y="4" width="4" height="16" rx="1"/><rect x="15" y="4" width="4" height="16" rx="1"/></svg>
                }
                else
                {
                    <svg class="w-4 h-4 ml-0.5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5.14v14l11-7a1 1 0 0 0 0-1.72l-11-7z"/></svg>
                }
            </button>

            <button class="text-on-surface/50 hover:text-neon-purple transition-colors p-1" title="下一首" @onclick="Next">
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.811c0 .864.933 1.405 1.683.977l7.108-4.062a1.125 1.125 0 000-1.953L4.683 7.712A1.125 1.125 0 003 8.688v8.123zM12.75 16.811c0 .864.933 1.405 1.683.977l7.108-4.062a1.125 1.125 0 000-1.953l-7.108-4.062a1.125 1.125 0 00-1.683.977v8.123z"/></svg>
            </button>
            <button class="text-on-surface/40 hover:text-neon-purple transition-colors p-1" title="列表循环">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/></svg>
            </button>
        </div>
        <div class="flex items-center gap-3 w-full">
            <span class="text-[10px] text-on-surface/40 font-mono w-10 text-right">@FormatMs(Player.State.PositionMs)</span>
            <div class="flex-1 h-[2px] rounded-full bg-white/10 relative cursor-pointer group">
                <div class="h-[2px] rounded-full bg-gradient-to-r from-neon-purple to-indigo-500 transition-all" style="width:@Progress%"></div>
                <div class="absolute top-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-white shadow-[0_0_8px_rgba(168,85,247,0.8)] opacity-0 group-hover:opacity-100 transition-opacity" style="left:calc(@Progress% - 4px)"></div>
            </div>
            <span class="text-[10px] text-on-surface/40 font-mono w-10">@FormatMs(Player.State.DurationMs)</span>
        </div>
    </div>

    @* ── Right: Quality badge + Volume ── *@
    <div class="flex items-center gap-4 w-72 justify-end">
        @if (Player.State.CurrentTrack?.Format is not null)
        {
            <span class="text-[9px] px-2 py-0.5 rounded bg-white/[0.04] border border-white/[0.05] text-on-surface/40 font-mono tracking-wider uppercase shrink-0">
                @Player.State.CurrentTrack.Format @(Player.State.CurrentTrack.SampleRate > 0 ? $"{Player.State.CurrentTrack.SampleRate / 1000}kHz" : "")
            </span>
        }
        <div class="flex items-center gap-2">
            <button class="text-on-surface/40 hover:text-neon-purple transition-colors p-1" title="静音">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z"/>
                </svg>
            </button>
            <input type="range" min="0" max="100" value="@((int)(Player.State.Volume * 100))"
                   @onchange="OnVolume"
                   class="w-20 h-[2px] rounded-full appearance-none bg-white/10 accent-neon-purple cursor-pointer
                          [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:w-2 [&::-webkit-slider-thumb]:h-2
                          [&::-webkit-slider-thumb]:rounded-full [&::-webkit-slider-thumb]:bg-white" />
        </div>
    </div>
</div>

@code {
    private double Progress => Player.State.DurationMs <= 0 ? 0 : Player.State.PositionMs * 100.0 / Player.State.DurationMs;

    private void TogglePlay()
    {
        if (Player.State.IsPlaying) Player.Pause(); else Player.Resume();
    }
    private void Prev() => Player.Previous();
    private void Next() => Player.Next();
    private void GoToNowPlaying() => Nav.NavigateTo("/nowplaying");

    private void OnVolume(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
            Player.SetVolume(v / 100.0);
    }

    private static string FormatMs(long ms)
    {
        if (ms <= 0) return "0:00";
        var t = TimeSpan.FromMilliseconds(ms);
        return $"{(int)t.TotalMinutes}:{t.Seconds:D2}";
    }
}

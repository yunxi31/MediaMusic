@page "/playlists"
@page "/playlists/{PlaylistId:long}"
@using MediaMusic.Data.Models
@using MediaMusic.Data.Repositories
@using MediaMusic.Services
@inject PlayerService Player
@inject PlaylistRepository PlaylistRepo
@inject TrackRepository TrackRepo

<PageTitle>播放列表 - MediaMusic</PageTitle>

<div class="playlist-page">
    <div class="playlist-header">
        <div class="cover-art-container">
            <img src="/images/midnight_jazz.png" alt="Playlist Cover" class="cover-art" />
        </div>
        <div class="playlist-info">
            <span class="playlist-label">播放列表</span>
            <h1 class="playlist-title">@PlaylistName</h1>
            <div class="playlist-meta">
                <span>@TrackCount 首曲目</span>
                <span>•</span>
                <span>@TotalSize</span>
                <span>•</span>
                <span class="badge-hires">无损 FLAC</span>
            </div>
            
            <div class="action-buttons">
                <button class="btn-play-all" @onclick="PlayAll">
                    <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                        <path d="M8 5v14l11-7z" />
                    </svg>
                    全部播放
                </button>
                <button class="btn-shuffle" @onclick="ShufflePlay">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
                        <polyline points="16 3 21 3 21 8"></polyline>
                        <line x1="4" y1="20" x2="21" y2="3"></line>
                        <polyline points="21 16 21 21 16 21"></polyline>
                        <line x1="15" y1="15" x2="21" y2="21"></line>
                        <line x1="4" y1="4" x2="9" y2="9"></line>
                    </svg>
                    随机播放
                </button>
                <button class="btn-add">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <div class="tracks-header">
        <div class="th-num">#</div>
        <div class="th-title">曲目 / 歌手</div>
        <div class="th-quality">音质</div>
        <div class="th-duration">时长</div>
    </div>

    <div class="tracks-list">
        @foreach (var (track, index) in Tracks.Select((t, i) => (t, i + 1)))
        {
            bool isActive = _activeTrackId == track.Id;
            <div class="track-row @(isActive ? "active" : "")" @onclick="() => SetActiveTrack(track.Id)">
                <div class="track-num">
                    @if (isActive)
                    {
                        <div class="eq-bars">
                            <div class="eq-bar"></div>
                            <div class="eq-bar"></div>
                            <div class="eq-bar"></div>
                            <div class="eq-bar"></div>
                        </div>
                    }
                    else
                    {
                        @index
                    }
                </div>
                <div class="track-info">
                    <span class="track-title">@track.Title</span>
                    <span class="track-artist">@track.ArtistName</span>
                </div>
                <div class="track-quality">
                    <span class="quality-badge">@GetQualityBadge(track)</span>
                </div>
                <div class="track-duration">
                    <span>@FormatDuration(track.DurationMs)</span>
                    <div class="track-actions">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                            <circle cx="5" cy="12" r="2"></circle>
                            <circle cx="12" cy="12" r="2"></circle>
                            <circle cx="19" cy="12" r="2"></circle>
                        </svg>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .playlist-page {
        height: 100%;
        display: flex;
        flex-direction: column;
        padding: 24px 32px;
        color: #ffffff;
        overflow-y: auto;
        background: linear-gradient(to bottom, #1a1625 0%, #111318 400px);
        scrollbar-width: none; /* Firefox */
    }

    .playlist-page::-webkit-scrollbar {
        display: none; /* Safari & Chrome */
    }

    .playlist-header {
        display: flex;
        gap: 24px;
        margin-bottom: 24px;
        align-items: flex-end;
    }

    .cover-art-container {
        width: 160px;
        height: 160px;
        flex-shrink: 0;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(168, 85, 247, 0.15);
        border: 1px solid rgba(255,255,255,0.05);
    }

    .cover-art {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .playlist-info {
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding-bottom: 4px;
    }

    .playlist-label {
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #b188ff;
        margin-bottom: 6px;
    }

    .playlist-title {
        font-size: 38px;
        font-weight: 800;
        letter-spacing: -1px;
        margin: 0 0 10px 0;
        color: #ffffff;
        line-height: 1.1;
    }

    .playlist-meta {
        font-size: 13px;
        color: #9ca3af;
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 500;
    }

    .badge-hires {
        font-size: 10px;
        font-weight: 700;
        padding: 1px 5px;
        border-radius: 4px;
        background-color: rgba(255, 255, 255, 0.08);
        color: #d1d5db;
        border: 1px solid rgba(255,255,255,0.15);
    }

    .action-buttons {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .btn-play-all {
        background-color: #c084fc; 
        color: #111318;
        border: none;
        padding: 10px 24px;
        border-radius: 9999px;
        font-size: 14px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
        white-space: nowrap;
    }
    .btn-play-all:hover {
        background-color: #d8b4fe;
        transform: scale(1.02);
    }

    .btn-shuffle {
        background-color: transparent;
        color: #e5e7eb;
        border: 1px solid rgba(255,255,255,0.3);
        padding: 9px 20px;
        border-radius: 9999px;
        font-size: 13px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
        white-space: nowrap;
    }
    .btn-shuffle:hover {
        background-color: rgba(255,255,255,0.05);
        border-color: rgba(255,255,255,0.5);
    }

    .btn-add {
        background-color: transparent;
        color: #e5e7eb;
        border: 1px solid rgba(255,255,255,0.3);
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .btn-add:hover {
        background-color: rgba(255,255,255,0.05);
        border-color: rgba(255,255,255,0.5);
        transform: scale(1.05);
    }

    /* Track List */
    .tracks-header {
        display: grid;
        grid-template-columns: 50px 1fr 140px 100px;
        padding: 12px 16px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        margin-bottom: 8px;
        color: #9ca3af;
        font-size: 13px;
        font-weight: 500;
        align-items: center;
    }
    
    .th-num { text-align: center; }
    .th-duration { text-align: right; padding-right: 48px; }

    .track-row {
        display: grid;
        grid-template-columns: 50px 1fr 140px 100px;
        padding: 10px 16px;
        border-radius: 8px;
        align-items: center;
        color: #d1d5db;
        transition: background-color 0.2s;
        cursor: pointer;
        position: relative;
    }

    .track-row:hover {
        background-color: rgba(255,255,255,0.04);
    }

    .track-row.active {
        background-color: rgba(255,255,255,0.08);
    }

    .track-num {
        font-size: 14px;
        color: #9ca3af;
        text-align: center;
    }

    .track-info {
        display: flex;
        flex-direction: column;
        gap: 4px;
        overflow: hidden;
        padding-right: 16px;
    }

    .track-title {
        font-size: 15px;
        font-weight: 600;
        color: #f3f4f6;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    
    .track-row.active .track-title {
        color: #c084fc; 
    }

    .track-artist {
        font-size: 13px;
        color: #9ca3af;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .track-quality {
        justify-self: start;
    }

    .quality-badge {
        font-size: 10px;
        font-weight: 600;
        padding: 3px 6px;
        border-radius: 4px;
        border: 1px solid rgba(255,255,255,0.15);
        color: #9ca3af;
        letter-spacing: 0.5px;
    }

    .track-row.active .quality-badge {
        color: #c084fc;
        border-color: rgba(192, 132, 252, 0.4);
    }

    .track-duration {
        font-size: 14px;
        color: #9ca3af;
        justify-self: end;
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .track-actions {
        opacity: 0;
        transition: opacity 0.2s;
        display: flex;
        align-items: center;
        color: #9ca3af;
    }

    .track-actions:hover {
        color: #fff;
    }

    .track-row:hover .track-actions {
        opacity: 1;
    }
    
    .track-row.active .track-actions {
        opacity: 1;
    }
    
    /* Equalizer animation */
    .eq-bars {
        display: flex;
        gap: 2px;
        height: 14px;
        align-items: flex-end;
        justify-content: center;
    }
    .eq-bar {
        width: 3px;
        background-color: #c084fc;
        animation: eq-bounce 1s infinite ease-in-out alternate;
        border-radius: 1px;
    }
    .eq-bar:nth-child(1) { animation-delay: 0.1s; height: 60%; }
    .eq-bar:nth-child(2) { animation-delay: 0.3s; height: 100%; }
    .eq-bar:nth-child(3) { animation-delay: 0.0s; height: 40%; }
    .eq-bar:nth-child(4) { animation-delay: 0.2s; height: 80%; }

    @@keyframes eq-bounce {
        0% { height: 20%; }
        100% { height: 100%; }
    }
</style>

@code {
    [Parameter]
    public long? PlaylistId { get; set; }

    private string PlaylistName = "Midnight Jazz";
    private string TotalSize = "3.2 GB";
    private int TrackCount = 48;
    private List<Track> Tracks = new();
    private long _activeTrackId = 2; // Default to match mock active state

    protected override async Task OnInitializedAsync()
    {
        if (PlaylistId.HasValue && PlaylistId.Value > 0)
        {
            await LoadPlaylistAsync(PlaylistId.Value);
        }
        else
        {
            LoadMockData();
        }
    }

    private async Task LoadPlaylistAsync(long id)
    {
        var playlist = await PlaylistRepo.GetByIdAsync(id);
        if (playlist != null)
        {
            PlaylistName = playlist.Name;
            var loadedTracks = await PlaylistRepo.GetTracksAsync(id);
            Tracks = loadedTracks.ToList();
            TrackCount = Tracks.Count;
            // Rough size estimation if missing
            TotalSize = $"{Math.Max(0.1, Tracks.Count * 0.03):F1} GB"; 
        }
    }

    private void LoadMockData()
    {
        // Setup mock data to perfectly match the design screenshot
        Tracks = new List<Track>
        {
            new Track { Id = 1, Title = "Round Midnight", ArtistName = "Thelonious Monk", Format = "24-bit/96kHz", DurationMs = 312000 },
            new Track { Id = 2, Title = "So What", ArtistName = "Miles Davis", Format = "24-bit/192kHz", DurationMs = 562000 },
            new Track { Id = 3, Title = "Take Five", ArtistName = "The Dave Brubeck Quartet", Format = "16-bit/44.1kHz", DurationMs = 324000 },
            new Track { Id = 4, Title = "Blue in Green", ArtistName = "Bill Evans", Format = "24-bit/96kHz", DurationMs = 337000 }
        };
    }

    private void PlayAll()
    {
        if (Tracks.Any())
        {
            // Simple mockup action - update active track to first
            _activeTrackId = Tracks.First().Id;
            StateHasChanged();
        }
    }

    private void ShufflePlay()
    {
        if (Tracks.Any())
        {
            var rnd = new Random();
            _activeTrackId = Tracks[rnd.Next(Tracks.Count)].Id;
            StateHasChanged();
        }
    }

    private void SetActiveTrack(long trackId)
    {
        _activeTrackId = trackId;
    }

    private string GetQualityBadge(Track track)
    {
        return !string.IsNullOrEmpty(track.Format) ? track.Format : "16-bit/44.1kHz";
    }

    private string FormatDuration(long? durationMs)
    {
        if (!durationMs.HasValue) return "--:--";
        var ts = TimeSpan.FromMilliseconds(durationMs.Value);
        return $"{(int)ts.TotalMinutes}:{ts.Seconds:D2}";
    }
}

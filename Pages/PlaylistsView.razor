@page "/playlists"
@page "/playlists/{PlaylistId:long}"
@using MediaMusic.Data.Models
@using MediaMusic.Data.Repositories
@using MediaMusic.Services
@using MediaMusic.Audio
@inject PlayerService Player
@inject PlaylistRepository PlaylistRepo
@inject TrackRepository TrackRepo
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>播放列表 - MediaMusic</PageTitle>

@if (!PlaylistId.HasValue)
{
    <div class="playlists-dashboard">
        <div class="dashboard-header">
            <div>
                <h1 class="dashboard-title">我的播放列表</h1>
                <p class="dashboard-subtitle">共 @_playlists.Count 个自建歌单</p>
            </div>
            <button class="btn-create-playlist" @onclick="OpenCreateDialog">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
                新建播放列表
            </button>
        </div>

        @if (_playlists.Count == 0)
        {
            <div class="playlists-empty-state">
                <svg class="empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M9 17H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-4" />
                    <polyline points="9 17 9 21 15 21 15 17" />
                    <circle cx="12" cy="10" r="3" />
                </svg>
                <p class="empty-title">暂无播放列表</p>
                <p class="empty-subtitle">创建一个播放列表，将您喜爱的音乐整理在一起</p>
                <button class="btn-create-playlist-empty" @onclick="OpenCreateDialog">
                    立即创建
                </button>
            </div>
        }
        else
        {
            <div class="playlists-grid">
                @foreach (var playlist in _playlists)
                {
                    var gradient = GetPlaylistGradient(playlist.Id);
                    var trackCount = _playlistTrackCounts.GetValueOrDefault(playlist.Id, 0);
                    <div class="playlist-card" @onclick="() => NavigateToPlaylist(playlist.Id)">
                        <div class="card-cover-wrapper" style="background: @gradient">
                            @if (!string.IsNullOrEmpty(_playlistCovers.GetValueOrDefault(playlist.Id)))
                            {
                                <img src="@_playlistCovers[playlist.Id]" alt="@playlist.Name" class="card-cover-img" />
                            }
                            else
                            {
                                <div class="card-cover-fallback">
                                    <svg class="fallback-note-icon" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M12 3v10.55A4 4 0 1 0 14 17V7h4V3h-6z" />
                                    </svg>
                                </div>
                            }

                            <div class="card-play-overlay">
                                <div class="card-play-btn" @onclick:stopPropagation="true" @onclick="() => PlayPlaylistAsync(playlist.Id)">
                                    <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                                        <path d="M8 5v14l11-7z" />
                                    </svg>
                                </div>
                            </div>
                        </div>
                        <div class="card-info">
                            <h3 class="card-name">@playlist.Name</h3>
                            <p class="card-tracks">@trackCount 首歌曲</p>
                        </div>
                        <button class="btn-card-delete" @onclick:stopPropagation="true" @onclick="() => DeletePlaylistAsync(playlist.Id)" title="删除歌单">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
                                <polyline points="3 6 5 6 21 6"></polyline>
                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                            </svg>
                        </button>
                    </div>
                }
            </div>
        }
    </div>
}
else
{
    <div class="playlist-page">
        <div class="back-navigation">
            <button class="btn-back" @onclick="GoBackToPlaylists">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                返回播放列表
            </button>
        </div>

        <div class="playlist-header">
            <div class="cover-art-container" style="background: @GetPlaylistGradient(PlaylistId.Value)">
                @if (!string.IsNullOrEmpty(_currentPlaylistCover))
                {
                    <img src="@_currentPlaylistCover" alt="@PlaylistName" class="cover-art" />
                }
                else
                {
                    <div class="cover-art-fallback">
                        <svg fill="currentColor" viewBox="0 0 24 24" width="48" height="48">
                            <path d="M12 3v10.55A4 4 0 1 0 14 17V7h4V3h-6z" />
                        </svg>
                    </div>
                }
            </div>
            <div class="playlist-info">
                <span class="playlist-label">播放列表</span>
                <h1 class="playlist-title">@PlaylistName</h1>
                <div class="playlist-meta">
                    <span>@TrackCount 首曲目</span>
                    <span>•</span>
                    <span>@TotalSize</span>
                    <span>•</span>
                    <span class="badge-hires">无损 FLAC</span>
                </div>
                
                <div class="action-buttons">
                    <button class="btn-play-all" @onclick="PlayAll" disabled="@(Tracks.Count == 0)">
                        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                            <path d="M8 5v14l11-7z" />
                        </svg>
                        全部播放
                    </button>
                    <button class="btn-shuffle" @onclick="ShufflePlay" disabled="@(Tracks.Count == 0)">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
                            <polyline points="16 3 21 3 21 8"></polyline>
                            <line x1="4" y1="20" x2="21" y2="3"></line>
                            <polyline points="21 16 21 21 16 21"></polyline>
                            <line x1="15" y1="15" x2="21" y2="21"></line>
                            <line x1="4" y1="4" x2="9" y2="9"></line>
                        </svg>
                        随机播放
                    </button>
                    <button class="btn-add" @onclick="OpenAddTracksDialog" title="添加歌曲">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                            <line x1="12" y1="5" x2="12" y2="19"></line>
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                        </svg>
                    </button>
                    <button class="btn-delete" @onclick="() => DeletePlaylistAsync(PlaylistId.Value)" title="删除歌单">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                            <polyline points="3 6 5 6 21 6"></polyline>
                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        @if (Tracks.Count == 0)
        {
            <div class="tracks-empty-state">
                <p>此播放列表内暂无曲目</p>
                <button class="btn-add-tracks-inline" @onclick="OpenAddTracksDialog">添加曲目</button>
            </div>
        }
        else
        {
            <div class="tracks-header">
                <div class="th-num">#</div>
                <div class="th-title">曲目 / 歌手</div>
                <div class="th-quality">音质</div>
                <div class="th-duration">时长</div>
            </div>

            <div class="tracks-list">
                @foreach (var (track, index) in Tracks.Select((t, i) => (t, i + 1)))
                {
                    bool isActive = Player.State.CurrentTrack?.Id == track.Id;
                    <div class="track-row @(isActive ? "active" : "")" @onclick="() => PlayTrack(track)">
                        <div class="track-num">
                            @if (isActive && Player.State.IsPlaying)
                            {
                                <div class="eq-bars">
                                    <div class="eq-bar"></div>
                                    <div class="eq-bar"></div>
                                    <div class="eq-bar"></div>
                                    <div class="eq-bar"></div>
                                </div>
                            }
                            else
                            {
                                @index
                            }
                        </div>
                        <div class="track-info">
                            <span class="track-title">@track.Title</span>
                            <span class="track-artist">@track.ArtistName</span>
                        </div>
                        <div class="track-quality">
                            <span class="quality-badge">@GetQualityBadge(track)</span>
                        </div>
                        <div class="track-duration">
                            <span>@FormatDuration(track.DurationMs)</span>
                            <button class="track-btn-remove" @onclick:stopPropagation="true" @onclick="() => RemoveTrack(track.Id)" title="移出播放列表">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
                                    <line x1="18" y1="6" x2="6" y2="18"></line>
                                    <line x1="6" y1="6" x2="18" y2="18"></line>
                                </svg>
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@* ─── Create Playlist Modal ─── *@
@if (_showCreateDialog)
{
    <div class="modal-backdrop" @onclick="CloseCreateDialog">
        <div class="modal-content" @onclick:stopPropagation="true">
            <h2 class="modal-title">新建播放列表</h2>
            <div class="modal-body">
                <input type="text" 
                       class="modal-input" 
                       placeholder="播放列表名称" 
                       @bind="_newPlaylistName" 
                       @bind:event="oninput"
                       @onkeydown="OnCreateInputKeyDown"
                       autofocus />
            </div>
            <div class="modal-actions">
                <button class="btn-modal-cancel" @onclick="CloseCreateDialog">取消</button>
                <button class="btn-modal-submit" @onclick="CreatePlaylistAsync" disabled="@string.IsNullOrWhiteSpace(_newPlaylistName)">创建</button>
            </div>
        </div>
    </div>
}

@* ─── Add Tracks Modal ─── *@
@if (_showAddTracksDialog)
{
    <div class="modal-backdrop" @onclick="CloseAddTracksDialog">
        <div class="modal-content modal-content-large" @onclick:stopPropagation="true">
            <div class="modal-header-row">
                <h2 class="modal-title">添加歌曲到播放列表</h2>
                <button class="btn-modal-close" @onclick="CloseAddTracksDialog">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>

            <div class="modal-search">
                <input type="text" 
                       class="modal-input search-input" 
                       placeholder="搜索曲目、歌手..." 
                       value="@_addTracksSearchQuery" 
                       @oninput="OnAddTracksSearchInput" />
            </div>

            <div class="modal-tracks-list">
                @if (_filteredLibraryTracks.Count == 0)
                {
                    <div class="modal-empty">
                        <p>未找到匹配的音乐</p>
                    </div>
                }
                else
                {
                    @foreach (var track in _filteredLibraryTracks)
                    {
                        var isAlreadyAdded = Tracks.Any(t => t.Id == track.Id);
                        <div class="modal-track-row">
                            <div class="modal-track-info">
                                <span class="modal-track-title">@track.Title</span>
                                <span class="modal-track-artist">@track.ArtistName</span>
                            </div>
                            @if (isAlreadyAdded)
                            {
                                <span class="badge-added">已添加</span>
                            }
                            else
                            {
                                <button class="btn-track-add" @onclick="() => AddTrackToPlaylistAsync(track)">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
                                        <line x1="12" y1="5" x2="12" y2="19"></line>
                                        <line x1="5" y1="12" x2="19" y2="12"></line>
                                    </svg>
                                </button>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

<style>
    /* Playlists Dashboard Styles */
    .playlists-dashboard {
        height: 100%;
        display: flex;
        flex-direction: column;
        padding: 28px 36px 40px;
        background-color: rgb(var(--background));
        color: rgb(var(--on-surface));
        overflow-y: auto;
    }
    
    .playlists-dashboard::-webkit-scrollbar { display: none; }
    .playlists-dashboard { -ms-overflow-style: none; scrollbar-width: none; }

    .dashboard-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 28px;
    }

    .dashboard-title {
        font-size: 28px;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: rgb(var(--on-surface));
    }

    .dashboard-subtitle {
        font-size: 13px;
        color: rgb(var(--on-surface) / 0.45);
        margin-top: 4px;
        font-weight: 500;
    }

    .btn-create-playlist {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 24px;
        font-size: 13px;
        font-weight: 700;
        color: #111318;
        background: #c084fc;
        border: none;
        border-radius: 9999px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-create-playlist:hover {
        background: #d8b4fe;
        transform: scale(1.02);
    }

    /* Playlists Grid */
    .playlists-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 24px;
    }

    .playlist-card {
        display: flex;
        flex-direction: column;
        background: rgb(var(--on-surface) / 0.02);
        border: 1px solid rgb(var(--on-surface) / 0.05);
        border-radius: 12px;
        padding: 16px;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
    }

    .playlist-card:hover {
        background: rgb(var(--on-surface) / 0.06);
        border-color: rgba(168, 85, 247, 0.3);
        transform: translateY(-4px);
    }

    .card-cover-wrapper {
        aspect-ratio: 1/1;
        border-radius: 8px;
        overflow: hidden;
        position: relative;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card-cover-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .card-cover-fallback {
        color: rgb(var(--on-surface) / 0.65);
    }

    .fallback-note-icon {
        width: 48px;
        height: 48px;
    }

    .card-play-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.2s ease;
    }

    .playlist-card:hover .card-play-overlay {
        opacity: 1;
    }

    .card-play-btn {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: #a855f7;
        color: rgb(var(--on-surface));
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 12px rgba(168, 85, 247, 0.4);
        transform: scale(0.9);
        transition: transform 0.2s ease;
    }

    .card-play-overlay:hover .card-play-btn {
        transform: scale(1.05);
        background: #b55fe6;
    }

    .card-info {
        margin-top: 12px;
    }

    .card-name {
        font-size: 14px;
        font-weight: 700;
        color: rgb(var(--on-surface) / 0.95);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .card-tracks {
        font-size: 12px;
        color: rgb(var(--on-surface) / 0.4);
        margin-top: 3px;
        font-weight: 500;
    }

    .btn-card-delete {
        position: absolute;
        bottom: 16px;
        right: 16px;
        background: transparent;
        border: none;
        color: rgb(var(--on-surface) / 0.3);
        cursor: pointer;
        opacity: 0;
        transition: opacity 0.2s, color 0.2s;
    }

    .playlist-card:hover .btn-card-delete {
        opacity: 1;
    }

    .btn-card-delete:hover {
        color: #ef4444;
    }

    /* Empty States */
    .playlists-empty-state {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 80px 20px;
        text-align: center;
    }

    .playlists-empty-state .empty-icon {
        width: 64px;
        height: 64px;
        color: rgb(var(--on-surface) / 0.15);
        margin-bottom: 20px;
    }

    .empty-title {
        font-size: 16px;
        font-weight: 700;
        color: rgb(var(--on-surface) / 0.85);
        margin-bottom: 8px;
    }

    .empty-subtitle {
        font-size: 13px;
        color: rgb(var(--on-surface) / 0.4);
        margin-bottom: 24px;
        max-width: 320px;
        line-height: 1.5;
    }

    .btn-create-playlist-empty {
        padding: 10px 32px;
        font-size: 13px;
        font-weight: 700;
        color: #111318;
        background: #c084fc;
        border: none;
        border-radius: 9999px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-create-playlist-empty:hover {
        background: #d8b4fe;
        transform: scale(1.02);
    }

    /* Playlist Details Page Styles */
    .playlist-page {
        height: 100%;
        display: flex;
        flex-direction: column;
        padding: 24px 32px;
        color: rgb(var(--on-surface));
        overflow-y: auto;
        background: rgb(var(--background));
        scrollbar-width: none;
    }

    .playlist-page::-webkit-scrollbar {
        display: none;
    }

    .back-navigation {
        margin-bottom: 20px;
    }

    .btn-back {
        display: flex;
        align-items: center;
        gap: 8px;
        background: transparent;
        border: none;
        color: rgb(var(--on-surface) / 0.5);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        padding: 6px 12px;
        border-radius: 6px;
        transition: all 0.2s;
    }

    .btn-back:hover {
        color: rgb(var(--on-surface));
        background: rgb(var(--on-surface) / 0.04);
    }

    .playlist-header {
        display: flex;
        gap: 24px;
        margin-bottom: 24px;
        align-items: flex-end;
    }

    .cover-art-container {
        width: 160px;
        height: 160px;
        flex-shrink: 0;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(168, 85, 247, 0.15);
        border: 1px solid rgb(var(--on-surface) /0.05);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .cover-art {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .cover-art-fallback {
        color: rgb(var(--on-surface) / 0.65);
    }

    .playlist-info {
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding-bottom: 4px;
    }

    .playlist-label {
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #b188ff;
        margin-bottom: 6px;
    }

    .playlist-title {
        font-size: 38px;
        font-weight: 800;
        letter-spacing: -1px;
        margin: 0 0 10px 0;
        color: rgb(var(--on-surface));
        line-height: 1.1;
    }

    .playlist-meta {
        font-size: 13px;
        color: rgb(var(--on-surface-muted));
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 500;
    }

    .badge-hires {
        font-size: 10px;
        font-weight: 700;
        padding: 1px 5px;
        border-radius: 4px;
        background-color: rgb(var(--on-surface) / 0.08);
        color: rgb(var(--on-surface) / 0.8);
        border: 1px solid rgb(var(--on-surface) /0.15);
    }

    .action-buttons {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .btn-play-all {
        background-color: #c084fc; 
        color: #111318;
        border: none;
        padding: 10px 24px;
        border-radius: 9999px;
        font-size: 14px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
        white-space: nowrap;
    }
    .btn-play-all:hover:not(:disabled) {
        background-color: #d8b4fe;
        transform: scale(1.02);
    }

    .btn-shuffle {
        background-color: transparent;
        color: rgb(var(--on-surface) / 0.9);
        border: 1px solid rgb(var(--on-surface) /0.3);
        padding: 9px 20px;
        border-radius: 9999px;
        font-size: 13px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
        white-space: nowrap;
    }
    .btn-shuffle:hover:not(:disabled) {
        background-color: rgb(var(--on-surface) /0.05);
        border-color: rgb(var(--on-surface) /0.5);
    }

    .btn-play-all:disabled, .btn-shuffle:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none !important;
    }

    .btn-add {
        background-color: transparent;
        color: rgb(var(--on-surface) / 0.9);
        border: 1px solid rgb(var(--on-surface) /0.3);
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .btn-add:hover {
        background-color: rgb(var(--on-surface) /0.05);
        border-color: rgb(var(--on-surface) /0.5);
        transform: scale(1.05);
    }

    .btn-delete {
        background-color: transparent;
        color: #ef4444;
        border: 1px solid rgba(239, 68, 68, 0.3);
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;

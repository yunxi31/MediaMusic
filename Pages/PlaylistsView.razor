@code {
    [Parameter]
    public long? PlaylistId { get; set; }

    private List<Playlist> _playlists = new();
    private Dictionary<long, int> _playlistTrackCounts = new();
    private Dictionary<long, string?> _playlistCovers = new();

    private string PlaylistName = "";
    private string TotalSize = "0 GB";
    private int TrackCount = 0;
    private List<Track> Tracks = new();
    private string? _currentPlaylistCover;

    private bool _showCreateDialog;
    private string _newPlaylistName = "";

    private bool _showAddTracksDialog;
    private string _addTracksSearchQuery = "";
    private List<Track> _filteredLibraryTracks = new();

    protected override void OnInitialized()
    {
        Player.StateChanged += OnPlayerStateChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (PlaylistId.HasValue && PlaylistId.Value > 0)
        {
            await LoadPlaylistAsync(PlaylistId.Value);
        }
        else
        {
            await LoadAllPlaylistsAsync();
        }
    }

    private void OnPlayerStateChanged(object? sender, EventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task LoadAllPlaylistsAsync()
    {
        var playlistsList = (await PlaylistRepo.GetAllAsync()).ToList();
        _playlistTrackCounts.Clear();
        _playlistCovers.Clear();

        foreach (var p in playlistsList)
        {
            var tracks = (await PlaylistRepo.GetTracksAsync(p.Id)).ToList();
            _playlistTrackCounts[p.Id] = tracks.Count;
            _playlistCovers[p.Id] = tracks.FirstOrDefault()?.CoverPath;
        }

        _playlists = playlistsList;
    }

    private async Task LoadPlaylistAsync(long id)
    {
        var playlist = await PlaylistRepo.GetByIdAsync(id);
        if (playlist != null)
        {
            PlaylistName = playlist.Name;
            var loadedTracks = (await PlaylistRepo.GetTracksAsync(id)).ToList();
            Tracks = loadedTracks;
            TrackCount = Tracks.Count;
            _currentPlaylistCover = Tracks.FirstOrDefault()?.CoverPath;

            // Compute total size and format nicely
            long totalBytes = Tracks.Sum(t => (long)(t.BitRate > 0 && t.DurationMs > 0
                ? (double)t.BitRate * t.DurationMs / 8.0
                : 0));
            TotalSize = FormatSize(totalBytes);
        }
        else
        {
            // Playlist not found, navigate back to list
            Nav.NavigateTo("/playlists");
        }
    }

    private void NavigateToPlaylist(long id)
    {
        Nav.NavigateTo($"/playlists/{id}");
    }

    private void GoBackToPlaylists()
    {
        Nav.NavigateTo("/playlists");
    }

    private void OpenCreateDialog()
    {
        _newPlaylistName = "";
        _showCreateDialog = true;
    }

    private void CloseCreateDialog()
    {
        _showCreateDialog = false;
        _newPlaylistName = "";
    }

    private async Task OnCreateInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_newPlaylistName))
        {
            await CreatePlaylistAsync();
        }
        else if (e.Key == "Escape")
        {
            CloseCreateDialog();
        }
    }

    private async Task CreatePlaylistAsync()
    {
        if (string.IsNullOrWhiteSpace(_newPlaylistName)) return;

        var name = _newPlaylistName.Trim();
        var newId = await PlaylistRepo.CreateAsync(name);
        
        CloseCreateDialog();
        
        // Navigate to the newly created playlist
        Nav.NavigateTo($"/playlists/{newId}");
    }

    private async Task DeletePlaylistAsync(long id)
    {
        await PlaylistRepo.DeleteAsync(id);
        if (PlaylistId.HasValue && PlaylistId.Value == id)
        {
            Nav.NavigateTo("/playlists");
        }
        else
        {
            await LoadAllPlaylistsAsync();
        }
    }

    private void PlayAll()
    {
        if (Tracks.Any())
        {
            Player.PlayQueue(Tracks, 0);
        }
    }

    private void ShufflePlay()
    {
        if (Tracks.Any())
        {
            if (!Player.State.IsShuffled)
            {
                Player.ToggleShuffle();
            }
            var rnd = new Random();
            Player.PlayQueue(Tracks, rnd.Next(Tracks.Count));
        }
    }

    private async Task PlayPlaylistAsync(long playlistId)
    {
        var tracks = (await PlaylistRepo.GetTracksAsync(playlistId)).ToList();
        if (tracks.Any())
        {
            Player.PlayQueue(tracks, 0);
        }
    }

    private void PlayTrack(Track track)
    {
        var idx = Tracks.FindIndex(t => t.Id == track.Id);
        if (idx >= 0)
        {
            Player.PlayQueue(Tracks, idx);
        }
        else
        {
            Player.Play(track);
        }
    }

    private async Task RemoveTrack(long trackId)
    {
        if (PlaylistId.HasValue)
        {
            await PlaylistRepo.RemoveTrackAsync(PlaylistId.Value, trackId);
            await LoadPlaylistAsync(PlaylistId.Value);
        }
    }

    private async Task OpenAddTracksDialog()
    {
        _addTracksSearchQuery = "";
        _showAddTracksDialog = true;
        await FilterLibraryTracksAsync();
    }

    private void CloseAddTracksDialog()
    {
        _showAddTracksDialog = false;
        _addTracksSearchQuery = "";
        _filteredLibraryTracks.Clear();
    }

    private async Task OnAddTracksSearchInput(ChangeEventArgs e)
    {
        _addTracksSearchQuery = e.Value?.ToString() ?? "";
        await FilterLibraryTracksAsync();
    }

    private async Task FilterLibraryTracksAsync()
    {
        _filteredLibraryTracks = (await TrackRepo.SearchAsync(null, null, null, _addTracksSearchQuery)).ToList();
    }

    private async Task AddTrackToPlaylistAsync(Track track)
    {
        if (PlaylistId.HasValue)
        {
            int sortOrder = Tracks.Count + 1;
            await PlaylistRepo.AddTrackAsync(PlaylistId.Value, track.Id, sortOrder);
            await LoadPlaylistAsync(PlaylistId.Value);
        }
    }

    private string GetPlaylistGradient(long playlistId)
    {
        var gradients = new[]
        {
            "linear-gradient(135deg, #a855f7 0%, #6366f1 100%)", // violet-to-indigo
            "linear-gradient(135deg, #ec4899 0%, #8b5cf6 100%)", // pink-to-purple
            "linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%)", // blue-to-darkblue
            "linear-gradient(135deg, #10b981 0%, #059669 100%)", // emerald-to-teal
            "linear-gradient(135deg, #f59e0b 0%, #d97706 100%)", // amber-to-orange
            "linear-gradient(135deg, #6366f1 0%, #ec4899 100%)", // indigo-to-pink
            "linear-gradient(135deg, #14b8a6 0%, #0891b2 100%)"  // teal-to-cyan
        };
        return gradients[playlistId % gradients.Length];
    }

    private string GetQualityBadge(Track track)
    {
        return !string.IsNullOrEmpty(track.Format) ? track.Format : "16-bit/44.1kHz";
    }

    private string FormatDuration(long? durationMs)
    {
        if (!durationMs.HasValue) return "--:--";
        var ts = TimeSpan.FromMilliseconds(durationMs.Value);
        return $"{(int)ts.TotalMinutes}:{ts.Seconds:D2}";
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):F1} GB";
    }

    public void Dispose()
    {
        Player.StateChanged -= OnPlayerStateChanged;
    }
}

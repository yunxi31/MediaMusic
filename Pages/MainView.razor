@page "/"
@inject PlayerService Player
@inject LyricsService Lyrics
@inject TrackRepository TrackRepo
@inject MediaMusic.Library.LibraryService LibraryService
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>MediaMusic - 首页</PageTitle>

<div class="home-page">
    <div class="home-glow home-glow-a"></div>
    <div class="home-glow home-glow-b"></div>

    <div class="home-inner">
        <header class="home-header">
            <div>
                <span class="hires-badge">HI-RES AUDIO</span>
                <h1>@Greeting，听友</h1>
            </div>

            <div class="home-actions">
                <button @onclick='() => Nav.NavigateTo("/notifications")' style="cursor: pointer;" class="icon-button" title="通知">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                    </svg>
                </button>
                <a @onclick='() => Nav.NavigateTo("/eq")' @onclick:preventDefault style="cursor: pointer;" class="icon-button" title="均衡器">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z" />
                    </svg>
                </a>
                <div class="home-avatar" title="个人中心">
                    <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&w=80&q=80" alt="Avatar" />
                </div>
            </div>
        </header>

        <section class="home-section">
            <div class="section-heading">
                <h2>最近播放</h2>
                <a @onclick='() => Nav.NavigateTo("/library")' @onclick:preventDefault style="cursor: pointer;">查看全部 <span>›</span></a>
            </div>

            <div class="recent-grid">
                @foreach (var track in RecentDisplayTracks.Take(3))
                {
                    var isSample = track.Track is null;
                    <button class="recent-card" disabled="@isSample" @onclick="() => OnDisplayTrackPlay(track)">
                        <span class="cover @track.CoverClass">
                            <span class="quality-badge">@track.Badge</span>
                            <span class="play-overlay">
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                            </span>
                        </span>
                        <span class="recent-title">@track.Title</span>
                        <span class="recent-artist">@track.Artist</span>
                    </button>
                }
            </div>
        </section>

        <section class="home-section tracks-section">
            <h2>全部曲目</h2>

            <div class="track-table">
                <div class="track-row table-head">
                    <span>#</span>
                    <span>标题</span>
                    <span>艺术家</span>
                    <span>专辑</span>
                    <span>格式</span>
                    <span class="track-duration">时长</span>
                </div>

                @for (var i = 0; i < TableDisplayTracks.Count; i++)
                {
                    var track = TableDisplayTracks[i];
                    var idx = i + 1;
                    var isSample = track.Track is null;
                    var isCurrent = track.Track != null && Player.State.CurrentTrack?.Id == track.Track.Id;
                    var isPlaying = isCurrent && Player.State.IsPlaying;
                    var isHighlightedSample = idx == 1 && isSample;

                    <button class="track-row track-item @(isCurrent || isHighlightedSample ? "active" : "")"
                            disabled="@isSample"
                            @onclick="() => OnDisplayTrackPlay(track)"
                            @oncontextmenu="(e) => OnTrackContextMenu(e, track)"
                            @oncontextmenu:preventDefault>
                        <span class="track-index">
                            @if (isPlaying || isHighlightedSample)
                            {
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M11 5H7v14h4V5Zm6 0h-4v14h4V5Z"/></svg>
                            }
                            else
                            {
                                @idx
                            }
                        </span>
                        <span class="track-title">@track.Title</span>
                        <span>@track.Artist</span>
                        <span>@track.Album</span>
                        <span><span class="format-pill">@track.Format</span></span>
                        <span class="track-duration">@track.Duration</span>
                    </button>
                }
            </div>
        </section>

        <!-- Context Menu -->
        @if (_showContextMenu)
        {
            <div class="context-menu-backdrop" @onclick="CloseContextMenu"></div>
            <div class="context-menu" style="position: fixed; left: @(_menuX)px; top: @(_menuY)px; z-index: 1200;">
                <button class="context-menu-item" @onclick="OpenEditModal">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" style="margin-right: 8px;">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                        <path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                    </svg>
                    编辑
                </button>
                <button class="context-menu-item" @onclick="RemoveTrackAsync" style="color: #ef4444;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" style="margin-right: 8px;">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="8" y1="12" x2="16" y2="12"></line>
                    </svg>
                    移除
                </button>
            </div>
        }

        <!-- Edit Metadata Modal -->
        @if (_showEditModal && _editingTrack != null)
        {
            <div class="modal-backdrop" @onclick="CloseEditModal">
                <div class="metadata-modal" @onclick:stopPropagation>
                    <div class="modal-header">
                        <h3>编辑元数据</h3>
                        <button class="close-btn" @onclick="CloseEditModal">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                        </button>
                    </div>
                    
                    <div class="modal-body">
                        <!-- Left Column: Cover art -->
                        <div class="modal-cover-column">
                            <div class="modal-cover-preview">
                                @if (!string.IsNullOrEmpty(_editCoverPath))
                                {
                                    <img src="@_editCoverPath" alt="Cover Preview" />
                                }
                                else
                                {
                                    <div class="modal-cover-fallback">
                                        <svg fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M12 3v10.55A4 4 0 1 0 14 17V7h4V3h-6z" />
                                        </svg>
                                    </div>
                                }
                                
                                <label for="cover-file-input" class="cover-upload-overlay">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
                                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                                        <polyline points="17 8 12 3 7 8"></polyline>
                                        <line x1="12" y1="3" x2="12" y2="15"></line>
                                    </svg>
                                    <span>选择封面图片</span>
                                </label>
                                <InputFile id="cover-file-input" OnChange="OnCoverFileChange" style="display: none;" accept="image/jpeg,image/png" />
                            </div>
                            
                            <div class="cover-specs">
                                @if (_coverSizeBytes > 0)
                                {
                                    <div class="specs-text">@($"{_coverWidth} x {_coverHeight} px • {FormatSize(_coverSizeBytes)}")</div>
                                }
                                else
                                {
                                    <div class="specs-text">无封面图片数据</div>
                                }
                                <div class="specs-format">@(_coverMimeType ?? "未知格式")</div>
                            </div>
                        </div>
                        
                        <!-- Right Column: Fields -->
                        <div class="modal-fields-column">
                            <div class="input-group">
                                <label>标题</label>
                                <input type="text" @bind="_editTitle" placeholder="请输入歌名" />
                            </div>
                            
                            <div class="input-group">
                                <label>艺术家</label>
                                <input type="text" @bind="_editArtist" placeholder="请输入艺术家" />
                            </div>
                            
                            <div class="input-group">
                                <label>专辑</label>
                                <input type="text" @bind="_editAlbum" placeholder="请输入专辑" />
                            </div>
                            
                            <div class="input-row-three">
                                <div class="input-group">
                                    <label>流派</label>
                                    <input type="text" @bind="_editGenre" placeholder="流派" />
                                </div>
                                <div class="input-group">
                                    <label>年份</label>
                                    <input type="number" @bind="_editYear" placeholder="年份" />
                                </div>
                                <div class="input-group track-no-group">
                                    <label>轨道</label>
                                    <div class="track-no-inputs">
                                        <input type="number" @bind="_editTrackNo" placeholder="号" />
                                        <span class="divider">/</span>
                                        <input type="number" @bind="_editTotalTracks" placeholder="总" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="modal-footer">
                        <button class="btn-cancel" @onclick="CloseEditModal">取消</button>
                        <button class="btn-save" @onclick="SaveMetadataChanges" disabled="@_isSaving">
                            @if (_isSaving)
                            {
                                <span>保存中...</span>
                            }
                            else
                            {
                                <span>保存修改</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private List<MediaMusic.Data.Models.Track> _allTracks = new();
    private List<MediaMusic.Data.Models.Track> _recentlyPlayed = new();

    // Context Menu Fields
    private bool _showContextMenu;
    private double _menuX;
    private double _menuY;
    private HomeDisplayTrack? _contextMenuTrack;

    // Modal Fields
    private bool _showEditModal;
    private bool _isSaving;
    private MediaMusic.Data.Models.Track? _editingTrack;

    // Metadata form fields
    private string? _editTitle;
    private string? _editArtist;
    private string? _editAlbum;
    private string? _editGenre;
    private int? _editYear;
    private int? _editTrackNo;
    private int? _editTotalTracks;

    // Cover fields
    private byte[]? _newCoverBytes;
    private string? _editCoverPath;
    private int _coverWidth;
    private int _coverHeight;
    private long _coverSizeBytes;
    private string? _coverMimeType;

    private string Greeting => GetGreeting();
    private IReadOnlyList<HomeDisplayTrack> RecentDisplayTracks => BuildDisplayTracks(_recentlyPlayed).Take(3).ToList();
    private IReadOnlyList<HomeDisplayTrack> TableDisplayTracks => BuildDisplayTracks(_allTracks).Take(8).ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();

        if (Player.State.CurrentTrack != null)
        {
            Lyrics.LoadForTrack(Player.State.CurrentTrack.FilePath);
        }

        Player.StateChanged += OnPlayerStateChanged;
    }

    private async Task LoadData()
    {
        _allTracks = (await TrackRepo.SearchAsync(null, null, null, null)).ToList();

        _recentlyPlayed = _allTracks
            .OrderByDescending(t => SafeParseDate(t.LastPlayed))
            .ThenByDescending(t => SafeParseDate(t.DateAdded))
            .Take(6)
            .ToList();
    }

    private static DateTime SafeParseDate(string? dateStr)
    {
        if (string.IsNullOrEmpty(dateStr)) return DateTime.MinValue;
        if (DateTime.TryParse(dateStr, out var dt)) return dt;
        return DateTime.MinValue;
    }

    private string GetGreeting()
    {
        var hour = DateTime.Now.Hour;
        if (hour < 5) return "深夜好";
        if (hour < 9) return "早上好";
        if (hour < 12) return "上午好";
        if (hour < 18) return "下午好";
        return "晚上好";
    }

    private async void OnPlayerStateChanged(object? sender, EventArgs e)
    {
        if (Player.State.CurrentTrack != null)
        {
            Lyrics.LoadForTrack(Player.State.CurrentTrack.FilePath);
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task OnPlay(MediaMusic.Data.Models.Track track)
    {
        Lyrics.LoadForTrack(track.FilePath);
        Player.Play(track);

        await TrackRepo.IncrementPlayCountAsync(track.Id);
        await LoadData();
        await InvokeAsync(StateHasChanged);
    }

    private Task OnDisplayTrackPlay(HomeDisplayTrack displayTrack)
    {
        return displayTrack.Track is null ? Task.CompletedTask : OnPlay(displayTrack.Track);
    }

    private static string FormatMs(long? ms)
    {
        if (ms is null or <= 0) return "--";
        var t = TimeSpan.FromMilliseconds(ms.Value);
        return $"{(int)t.TotalMinutes}:{t.Seconds:D2}";
    }

    private IReadOnlyList<HomeDisplayTrack> BuildDisplayTracks(IReadOnlyList<Track> source)
    {
        if (source.Count == 0)
        {
            return SampleTracks;
        }

        return source.Select((track, index) => new HomeDisplayTrack(
            track,
            track.Title ?? "未知标题",
            track.ArtistName ?? "未知艺术家",
            track.AlbumTitle ?? "未知专辑",
            FormatTechSpecs(track),
            FormatMs(track.DurationMs),
            GetQualityBadge(track),
            CoverClasses[index % CoverClasses.Length]
        )).ToList();
    }

    private string FormatTechSpecs(Track track)
    {
        if (string.IsNullOrEmpty(track.Format)) return "AUDIO";
        var fmt = track.Format.ToUpperInvariant();
        if (fmt == "FLAC" || fmt == "WAV" || fmt == "ALAC")
        {
            if (track.SampleRate > 0)
            {
                var bits = EstimateBitDepth(track);
                return $"{fmt} {bits}/{track.SampleRate.Value / 1000}";
            }

            return fmt;
        }

        if (fmt == "DSD") return "DSD128";
        if (fmt == "MQA") return "MQA";
        if (track.SampleRate > 0) return $"{fmt} {track.SampleRate.Value / 1000}kHz";
        return fmt;
    }

    private string GetQualityBadge(Track track)
    {
        if (string.IsNullOrEmpty(track.Format)) return "HI-RES";
        var fmt = track.Format.ToUpperInvariant();
        if (fmt == "FLAC" || fmt == "WAV" || fmt == "ALAC")
        {
            if (track.SampleRate > 0)
            {
                return $"{EstimateBitDepth(track)}/{track.SampleRate.Value / 1000}";
            }

            return fmt;
        }

        if (fmt == "DSD") return "DSD128";
        if (fmt == "MQA") return "MQA";
        return fmt;
    }

    private void OnTrackContextMenu(Microsoft.AspNetCore.Components.Web.MouseEventArgs e, HomeDisplayTrack displayTrack)
    {
        if (displayTrack.Track == null) return;
        _contextMenuTrack = displayTrack;
        _menuX = e.ClientX;
        _menuY = e.ClientY;
        _showContextMenu = true;
    }

    private void CloseContextMenu()
    {
        _showContextMenu = false;
    }

    private void CloseEditModal()
    {
        _showEditModal = false;
    }

    private async Task RemoveTrackAsync()
    {
        _showContextMenu = false;
        if (_contextMenuTrack?.Track == null) return;

        try
        {
            await TrackRepo.DeleteAsync(_contextMenuTrack.Track.Id);
            await LoadData();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception)
        {
            // Log/handle error
        }
    }

    private async Task OpenEditModal()
    {
        _showContextMenu = false;
        if (_contextMenuTrack?.Track == null) return;

        var track = await TrackRepo.GetByIdAsync(_contextMenuTrack.Track.Id);
        if (track == null) return;

        _editingTrack = track;
        _editTitle = track.Title;
        _editArtist = track.ArtistName;
        _editAlbum = track.AlbumTitle;
        _editGenre = track.GenreName;
        _editYear = track.Year;
        _editTrackNo = track.TrackNo;
        _editTotalTracks = track.TotalTracks;

        _newCoverBytes = null;
        _editCoverPath = track.CoverPath;
        PopulateCoverSpecs(track.CoverPath);

        _showEditModal = true;
    }

    private void PopulateCoverSpecs(string? coverPath)
    {
        if (string.IsNullOrEmpty(coverPath))
        {
            _coverWidth = 0;
            _coverHeight = 0;
            _coverSizeBytes = 0;
            _coverMimeType = null;
            return;
        }

        try
        {
            var absolutePath = coverPath;
            if (coverPath.StartsWith("/"))
            {
                absolutePath = Path.Combine(AppContext.BaseDirectory, "wwwroot", coverPath.TrimStart('/'));
            }

            if (File.Exists(absolutePath))
            {
                var fileInfo = new FileInfo(absolutePath);
                _coverSizeBytes = fileInfo.Length;
                var ext = Path.GetExtension(absolutePath).ToLowerInvariant();
                _coverMimeType = ext == ".png" ? "PNG Image" : "JPEG Image";
                _coverWidth = 1000;
                _coverHeight = 1000;
            }
        }
        catch
        {
            _coverWidth = 1000;
            _coverHeight = 1000;
            _coverSizeBytes = 0;
            _coverMimeType = "JPEG Image";
        }
    }

    private async Task OnCoverFileChange(Microsoft.AspNetCore.Components.Forms.InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            _coverSizeBytes = file.Size;
            _coverMimeType = file.ContentType == "image/png" ? "PNG Image" : "JPEG Image";

            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            _newCoverBytes = ms.ToArray();

            _editCoverPath = $"data:{file.ContentType};base64,{Convert.ToBase64String(_newCoverBytes)}";
            _coverWidth = 1000;
            _coverHeight = 1000;
        }
    }

    private static string FormatSize(long bytes)
    {
        if (bytes <= 0) return "0 B";
        string[] suffix = { "B", "KB", "MB", "GB" };
        int index = 0;
        double dblBytes = bytes;
        while (dblBytes >= 1024 && index < suffix.Length - 1)
        {
            dblBytes /= 1024;
            index++;
        }
        return $"{dblBytes:F1} {suffix[index]}";
    }

    private async Task SaveMetadataChanges()
    {
        if (_editingTrack == null || _isSaving) return;
        _isSaving = true;

        try
        {
            _editingTrack.Title = _editTitle;
            _editingTrack.ArtistName = _editArtist;
            _editingTrack.AlbumTitle = _editAlbum;
            _editingTrack.GenreName = _editGenre;
            _editingTrack.Year = _editYear;
            _editingTrack.TrackNo = _editTrackNo;
            _editingTrack.TotalTracks = _editTotalTracks;

            await LibraryService.EditMetadataAsync(_editingTrack, _newCoverBytes, null);

            _showEditModal = false;

            await LoadData();

            if (Player.State.CurrentTrack?.Id == _editingTrack.Id)
            {
                var updatedTrack = await TrackRepo.GetByIdAsync(_editingTrack.Id);
                if (updatedTrack != null)
                {
                    Player.State.CurrentTrack.Title = updatedTrack.Title;
                    Player.State.CurrentTrack.ArtistName = updatedTrack.ArtistName;
                    Player.State.CurrentTrack.AlbumTitle = updatedTrack.AlbumTitle;
                    Player.State.CurrentTrack.GenreName = updatedTrack.GenreName;
                    Player.State.CurrentTrack.Year = updatedTrack.Year;
                    Player.State.CurrentTrack.TrackNo = updatedTrack.TrackNo;
                    Player.State.CurrentTrack.CoverPath = updatedTrack.CoverPath;
                    Player.State.CurrentTrack.TotalTracks = updatedTrack.TotalTracks;
                    Player.NotifyStateChanged();
                }
            }
        }
        catch (Exception)
        {
            // Log/handle error
        }
        finally
        {
            _isSaving = false;
        }
    }

    private static int EstimateBitDepth(Track track)
    {
        var bits = 24;
        if (track.BitRate > 0 && track.SampleRate > 0)
        {
            var channels = track.Channels ?? 2;
            bits = (int)Math.Round((double)track.BitRate * 1000 / (track.SampleRate.Value * channels));
            if (bits <= 0 || bits > 32) bits = 24;
        }

        return bits;
    }

    public void Dispose()
    {
        Player.StateChanged -= OnPlayerStateChanged;
    }

    private sealed record HomeDisplayTrack(
        Track? Track,
        string Title,
        string Artist,
        string Album,
        string Format,
        string Duration,
        string Badge,
        string CoverClass);

    private static readonly string[] CoverClasses =
    [
        "cover-obsidian",
        "cover-lunar",
        "cover-vinyl",
        "cover-waves"
    ];

    private static readonly IReadOnlyList<HomeDisplayTrack> SampleTracks =
    [
        new(null, "Clarity", "The Midnight Resonance", "Nocturnal Elements", "FLAC 24/192", "4:12", "24/192", "cover-lunar"),
        new(null, "Echoes in Silence", "Aurelia", "Void Structures", "DSD128", "5:45", "DSD128", "cover-obsidian"),
        new(null, "Analog Drift", "Kaelen", "Machine Soul", "MQA", "3:58", "MQA", "cover-vinyl")
    ];
}

<style>
    .home-page {
        position: relative;
        width: 100%;
        height: 100%;
        overflow-y: auto;
        padding: 28px 36px 40px;
        background: rgb(var(--background));
        color: rgb(var(--on-surface));
        user-select: none;
    }

    .home-page::-webkit-scrollbar { display: none; }
    .home-page { -ms-overflow-style: none; scrollbar-width: none; }

    .home-glow {
        position: absolute;
        pointer-events: none;
        border-radius: 999px;
        filter: blur(100px);
    }

    .home-glow-a {
        left: 18%;
        top: 18%;
        width: 350px;
        height: 350px;
        background: rgba(168, 85, 247, 0.035);
    }

    .home-glow-b {
        right: 12%;
        bottom: 18%;
        width: 300px;
        height: 300px;
        background: rgba(34, 211, 238, 0.025);
    }

    .home-inner {
        position: relative;
        z-index: 1;
        width: min(980px, 100%);
        margin: 0 auto;
    }

    .home-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 24px;
        margin-bottom: 28px;
    }

    .hires-badge {
        display: inline-flex;
        align-items: center;
        height: 22px;
        padding: 0 10px;
        border: 1px solid rgba(245, 158, 11, 0.25);
        border-radius: 4px;
        background: rgba(245, 158, 11, 0.1);
        color: #fbbf24;
        font-size: 9px;
        font-weight: 800;
        letter-spacing: 0.08em;
    }

    .home-header h1 {
        margin-top: 8px;
        color: rgb(var(--on-surface));
        font-size: 25px;
        line-height: 1;
        font-weight: 800;
    }

    .home-actions {
        display: flex;
        align-items: center;
        gap: 18px;
        padding-top: 2px;
    }

    .icon-button {
        display: inline-flex;
        width: 18px;
        height: 18px;
        align-items: center;
        justify-content: center;
        color: rgba(var(--on-surface), 0.58);
        transition: color 150ms ease;
    }

    .icon-button:hover { color: rgb(var(--on-surface)); }
    .icon-button svg { width: 16px; height: 16px; }

    .home-avatar {
        width: 22px;
        height: 22px;
        overflow: hidden;
        border-radius: 50%;
        box-shadow: 0 0 0 1px rgb(var(--on-surface) /0.16);
    }


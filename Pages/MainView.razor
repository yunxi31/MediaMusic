@page "/"
@inject PlayerService Player
@inject LyricsService Lyrics
@inject TrackRepository TrackRepo
@implements IDisposable

<PageTitle>MediaMusic — 首页</PageTitle>

<div class="relative w-full h-full overflow-y-auto scrollbar-hide bg-background text-on-surface p-8 select-none z-10">
    @* Ambient background glow from album art/neon purple *@
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-1/4 left-1/4 w-[400px] h-[400px] rounded-full bg-neon-purple/5 blur-[120px]"></div>
        <div class="absolute bottom-1/4 right-1/4 w-[300px] h-[300px] rounded-full bg-indigo-500/5 blur-[100px]"></div>
    </div>

    <div class="relative z-10 space-y-8 max-w-7xl mx-auto">
        @* ── Header Greeting area ── *@
        <div class="flex items-center justify-between">
            <div class="space-y-1">
                <span class="inline-flex items-center text-[9px] font-extrabold tracking-widest px-2 py-0.5 rounded bg-amber-500/10 text-amber-400 border border-amber-500/20 uppercase shadow-sm">
                    HI-RES AUDIO
                </span>
                <h1 class="text-2xl font-bold tracking-wide text-gray-100">@Greeting，听友</h1>
            </div>
            
            <div class="flex items-center gap-4">
                @* Notification Bell *@
                <button class="relative p-2 rounded-xl bg-white/[0.02] border border-white/[0.04] text-on-surface/60 hover:text-white hover:bg-white/[0.05] hover:border-white/[0.08] transition-all shadow-sm" title="通知">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                    </svg>
                </button>
                @* Equalizer Navigation *@
                <NavLink href="/eq" class="p-2 rounded-xl bg-white/[0.02] border border-white/[0.04] text-on-surface/60 hover:text-white hover:bg-white/[0.05] hover:border-white/[0.08] transition-all shadow-sm" title="均衡器">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z" />
                    </svg>
                </NavLink>
                @* Avatar with premium halo *@
                <div class="w-8 h-8 rounded-full overflow-hidden border border-white/10 ring-2 ring-neon-purple/20 cursor-pointer hover:scale-105 transition-transform" title="个人中心">
                    <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&w=100&q=80" alt="Avatar" class="w-full h-full object-cover" />
                </div>
            </div>
        </div>

        @* ── Recently Played (最近播放) ── *@
        <div>
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-sm font-bold text-on-surface/50 uppercase tracking-wider">最近播放</h2>
                <NavLink href="/library" class="text-xs text-on-surface/40 hover:text-neon-purple transition-colors flex items-center gap-1">
                    查看全部 <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </NavLink>
            </div>

            @if (_recentlyPlayed.Count == 0)
            {
                <div class="rounded-2xl border border-white/[0.04] bg-white/[0.005] p-8 text-center text-on-surface/30 text-xs shadow-sm">
                    暂无最近播放曲目
                </div>
            }
            else
            {
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-6">
                    @foreach (var track in _recentlyPlayed)
                    {
                        <div class="group cursor-pointer relative" @onclick="() => OnPlay(track)">
                            <div class="relative rounded-xl overflow-hidden bg-gradient-to-br from-white/[0.03] to-black/[0.2] aspect-square mb-2.5 border border-white/[0.05] shadow-[0_4px_16px_rgba(0,0,0,0.2)] group-hover:shadow-[0_8px_24px_rgba(168,85,247,0.15)] group-hover:border-neon-purple/30 transition-all duration-300">
                                @if (!string.IsNullOrEmpty(track.CoverPath))
                                {
                                    <img src="@track.CoverPath" alt="@track.Title" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                                }
                                else
                                {
                                    <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-neon-purple/20 via-neutral-900 to-indigo-950/40 relative">
                                        <svg class="w-10 h-10 text-neon-purple/60 filter drop-shadow-[0_0_8px_rgba(168,85,247,0.3)] transition-transform duration-500 group-hover:scale-105" fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 10l12-3" />
                                            <circle cx="6" cy="19" r="3" fill="currentColor" />
                                            <circle cx="18" cy="16" r="3" fill="currentColor" />
                                        </svg>
                                    </div>
                                }
                                
                                @* Quality Badge *@
                                <div class="absolute top-2.5 right-2.5 text-[9px] px-1.5 py-0.5 rounded bg-black/75 text-white/95 font-semibold font-mono tracking-wider backdrop-blur-md border border-white/5 shadow-md">
                                    @GetQualityBadge(track)
                                </div>

                                @* Play Overlay *@
                                <div class="absolute inset-0 flex items-center justify-center bg-black/0 group-hover:bg-black/45 transition-all duration-300">
                                    <div class="w-11 h-11 rounded-full bg-neon-purple flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 scale-75 group-hover:scale-100 shadow-[0_0_15px_rgba(168,85,247,0.6)]">
                                        <svg class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M8 5v14l11-7z"/>
                                        </svg>
                                    </div>
                                </div>
                            </div>
                            <p class="text-xs font-semibold text-gray-200 truncate group-hover:text-neon-purple transition-colors duration-200">@(track.Title ?? "未知标题")</p>
                            <p class="text-[10px] text-on-surface/40 truncate mt-0.5 group-hover:text-on-surface/60 transition-colors duration-200">@(track.ArtistName ?? "未知艺术家")</p>
                        </div>
                    }
                </div>
            }
        </div>

        @* ── All Tracks (全部曲目) ── *@
        <div>
            <h2 class="text-sm font-bold text-on-surface/50 uppercase tracking-wider mb-4">全部曲目</h2>
            
            <div class="rounded-2xl border border-white/[0.04] bg-white/[0.005] overflow-hidden backdrop-blur-md shadow-lg">
                @* Table Header *@
                <div class="grid grid-cols-[50px_3.5fr_2fr_2fr_130px_70px] gap-4 border-b border-white/[0.04] px-6 py-3.5 text-[10px] font-extrabold uppercase tracking-wider text-on-surface/45 bg-white/[0.008] select-none items-center">
                    <span>#</span>
                    <span>标题</span>
                    <span>艺术家</span>
                    <span>专辑</span>
                    <span>格式</span>
                    <span class="text-right pr-2">时长</span>
                </div>

                @* Table Body *@
                @if (_allTracks.Count == 0)
                {
                    <div class="flex flex-col items-center justify-center p-16 text-center text-on-surface/30 text-xs gap-3">
                        <svg class="w-10 h-10 text-on-surface/20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 10l12-3M9 21a3 3 0 11-6 0 3 3 0 016 0zm12-3a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        <span>曲库为空 · 拖入音频文件即可播放，或导入本地目录</span>
                        <NavLink href="/library" class="mt-2 px-4 py-1.5 rounded-lg bg-neon-purple hover:bg-neon-purple/90 text-white font-semibold transition-all shadow-md">
                            前往导入
                        </NavLink>
                    </div>
                }
                else
                {
                    <div class="divide-y divide-white/[0.02] max-h-[520px] overflow-y-auto scrollbar-hide">
                        @for (int i = 0; i < _allTracks.Count; i++)
                        {
                            var idx = i + 1;
                            var track = _allTracks[i];
                            var isCurrent = Player.State.CurrentTrack?.Id == track.Id;
                            var isPlaying = isCurrent && Player.State.IsPlaying;

                            <div class="grid grid-cols-[50px_3.5fr_2fr_2fr_130px_70px] gap-4 px-6 py-3.5 text-xs items-center cursor-pointer hover:bg-white/[0.02] active:bg-white/[0.03] transition-all duration-200 group relative @(isCurrent ? "bg-neon-purple/[0.03]" : "")"
                                 @onclick="() => OnPlay(track)">
                                
                                @* Left Active Track Indicator Line *@
                                @if (isCurrent)
                                {
                                    <div class="absolute left-0 top-2.5 bottom-2.5 w-[3px] rounded-r bg-neon-purple shadow-[0_0_8px_rgba(168,85,247,0.8)]"></div>
                                }

                                @* Index / Playing Icon *@
                                <div class="text-on-surface/40 font-mono flex items-center">
                                    @if (isPlaying)
                                    {
                                        <div class="flex items-end gap-[2px] h-3 w-4" title="播放中">
                                            <span class="w-[2px] bg-neon-purple animate-[pulse_0.8s_infinite_alternate]" style="height: 100%;"></span>
                                            <span class="w-[2px] bg-neon-purple animate-[pulse_1.1s_infinite_alternate]" style="height: 60%;"></span>
                                            <span class="w-[2px] bg-neon-purple animate-[pulse_0.9s_infinite_alternate]" style="height: 85%;"></span>
                                        </div>
                                    }
                                    else if (isCurrent)
                                    {
                                        <svg class="w-3.5 h-3.5 text-neon-purple" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M8 5v14l11-7z"/>
                                        </svg>
                                    }
                                    else
                                    {
                                        <span class="group-hover:hidden">@idx</span>
                                        <svg class="w-3.5 h-3.5 text-on-surface/60 hidden group-hover:block" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M8 5v14l11-7z"/>
                                        </svg>
                                    }
                                </div>

                                @* Title & Cover Thumbnail *@
                                <div class="flex items-center gap-3 min-w-0">
                                    <div class="w-9 h-9 rounded-md overflow-hidden bg-white/[0.02] border border-white/5 flex items-center justify-center shrink-0 shadow-sm relative">
                                        @if (!string.IsNullOrEmpty(track.CoverPath))
                                        {
                                            <img src="@track.CoverPath" alt="" class="w-full h-full object-cover" />
                                        }
                                        else
                                        {
                                            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-neon-purple/10 to-neutral-900">
                                                <svg class="w-4 h-4 text-neon-purple/40" fill="currentColor" viewBox="0 0 24 24"><path d="M12 3v10.55A4 4 0 1 0 14 17V7h4V3h-6z"/></svg>
                                            </div>
                                        }
                                    </div>
                                    <span class="truncate font-semibold transition-colors duration-200 @(isCurrent ? "text-neon-purple" : "text-gray-200 group-hover:text-neon-purple")">
                                        @(track.Title ?? "未知标题")
                                    </span>
                                </div>

                                @* Artist *@
                                <span class="truncate transition-colors duration-200 @(isCurrent ? "text-neon-purple/80" : "text-on-surface/60 group-hover:text-on-surface/85")">
                                    @(track.ArtistName ?? "未知艺术家")
                                </span>

                                @* Album *@
                                <span class="truncate text-on-surface/40 group-hover:text-on-surface/60 transition-colors duration-200">
                                    @(track.AlbumTitle ?? "未知专辑")
                                </span>

                                @* Format Badge *@
                                <div>
                                    <span class="text-[9px] font-bold px-1.5 py-0.5 rounded font-mono bg-white/[0.03] text-on-surface/50 border border-white/[0.05] tracking-wider group-hover:text-on-surface/75 group-hover:border-white/[0.08] uppercase transition-all shadow-inner">
                                        @FormatTechSpecs(track)
                                    </span>
                                </div>

                                @* Duration *@
                                <span class="text-right text-on-surface/45 group-hover:text-on-surface/75 tabular-nums pr-2 transition-colors duration-200">
                                    @FormatMs(track.DurationMs)
                                </span>

                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<MediaMusic.Data.Models.Track> _allTracks = new();
    private List<MediaMusic.Data.Models.Track> _recentlyPlayed = new();

    private string Greeting => GetGreeting();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();

        if (Player.State.CurrentTrack != null)
        {
            Lyrics.LoadForTrack(Player.State.CurrentTrack.FilePath);
        }

        Player.StateChanged += OnPlayerStateChanged;
    }

    private async Task LoadData()
    {
        _allTracks = (await TrackRepo.SearchAsync(null, null, null, null)).ToList();
        
        // Sort recently played by LastPlayed desc, falling back to DateAdded desc.
        _recentlyPlayed = _allTracks
            .OrderByDescending(t => SafeParseDate(t.LastPlayed))
            .ThenByDescending(t => SafeParseDate(t.DateAdded))
            .Take(6)
            .ToList();
    }

    private static DateTime SafeParseDate(string? dateStr)
    {
        if (string.IsNullOrEmpty(dateStr)) return DateTime.MinValue;
        if (DateTime.TryParse(dateStr, out var dt)) return dt;
        return DateTime.MinValue;
    }

    private string GetGreeting()
    {
        var hour = DateTime.Now.Hour;
        if (hour < 5) return "深夜好";
        if (hour < 9) return "早上好";
        if (hour < 12) return "上午好";
        if (hour < 18) return "下午好";
        return "晚上好";
    }

    private async void OnPlayerStateChanged(object? sender, EventArgs e)
    {
        if (Player.State.CurrentTrack != null)
        {
            Lyrics.LoadForTrack(Player.State.CurrentTrack.FilePath);
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnPlay(MediaMusic.Data.Models.Track t)
    {
        Lyrics.LoadForTrack(t.FilePath);
        Player.Play(t);
        
        // Dynamically increment play count & update LastPlayed timestamp in DB
        await TrackRepo.IncrementPlayCountAsync(t.Id);
        
        // Reload lists to immediately update the Home View
        await LoadData();
        await InvokeAsync(StateHasChanged);
    }

    private static string FormatMs(long? ms)
    {
        if (ms is null or <= 0) return "—";
        var t = TimeSpan.FromMilliseconds(ms.Value);
        return $"{(int)t.TotalMinutes}:{t.Seconds:D2}";
    }

    private string FormatTechSpecs(Track track)
    {
        if (string.IsNullOrEmpty(track.Format)) return "AUDIO";
        var fmt = track.Format.ToUpper();
        if (fmt == "FLAC" || fmt == "WAV" || fmt == "ALAC")
        {
            if (track.SampleRate > 0)
            {
                int bits = 24;
                if (track.BitRate > 0 && track.SampleRate > 0)
                {
                    var ch = track.Channels ?? 2;
                    bits = (int)Math.Round((double)track.BitRate * 1000 / (track.SampleRate.Value * ch));
                    if (bits <= 0 || bits > 32) bits = 24;
                }
                return $"{fmt} {bits}/{track.SampleRate.Value / 1000}";
            }
            return fmt;
        }
        if (fmt == "DSD")
        {
            return "DSD128";
        }
        if (fmt == "MQA")
        {
            return "MQA";
        }
        if (track.SampleRate > 0)
        {
            return $"{fmt} {track.SampleRate.Value / 1000}kHz";
        }
        return fmt;
    }

    private string GetQualityBadge(Track track)
    {
        if (string.IsNullOrEmpty(track.Format)) return "HI-RES";
        var fmt = track.Format.ToUpper();
        if (fmt == "FLAC" || fmt == "WAV" || fmt == "ALAC")
        {
            if (track.SampleRate > 0)
            {
                int bits = 24;
                if (track.BitRate > 0 && track.SampleRate > 0)
                {
                    var ch = track.Channels ?? 2;
                    bits = (int)Math.Round((double)track.BitRate * 1000 / (track.SampleRate.Value * ch));
                    if (bits <= 0 || bits > 32) bits = 24;
                }
                return $"{bits}/{track.SampleRate.Value / 1000}";
            }
            return fmt;
        }
        if (fmt == "DSD")
        {
            return "DSD128";
        }
        if (fmt == "MQA")
        {
            return "MQA";
        }
        return fmt;
    }

    public void Dispose()
    {
        Player.StateChanged -= OnPlayerStateChanged;
    }
}

<style>
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

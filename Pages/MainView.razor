@page "/"
@inject PlayerService Player
@inject LyricsService Lyrics

<PageTitle>MediaMusic</PageTitle>

<div class="flex h-full">
    @* Left: cover + lyrics (PRD §2.3 main scroll view) *@
    <div class="flex w-1/2 flex-col items-center justify-center p-8 gap-6">
        <CoverArt Size="220" />
        <div class="text-center">
            <div class="text-xl font-semibold">@(Player.State.CurrentTrack?.Title ?? "MediaMusic")</div>
            <div class="text-on-surface/50">@(Player.State.CurrentTrack?.ArtistName ?? "本地无损播放器")</div>
        </div>

        <div class="w-full max-w-md h-64 overflow-auto rounded bg-surface-variant/40 p-4 text-center">
            @if (Lyrics.Lines.Count == 0)
            {
                <p class="text-on-surface/30 text-sm">暂无歌词 · 同名 .lrc 文件将自动匹配</p>
            }
            else
            {
                @foreach (var line in Lyrics.Lines)
                {
                    <p class="py-1 text-sm text-on-surface/60">@line.Text</p>
                }
            }
        </div>
    </div>

    @* Right: playlist (PRD §2.2) *@
    <div class="w-1/2 flex flex-col border-l border-on-surface/10">
        <div class="px-4 py-3 border-b border-on-surface/10 flex items-center justify-between">
            <h1 class="text-sm font-semibold uppercase tracking-wide text-on-surface/60">播放列表</h1>
            <div class="flex gap-2 text-xs">
                <NavLink class="hover:text-accent" href="/library">曲库</NavLink>
                <NavLink class="hover:text-accent" href="/eq">均衡器</NavLink>
            </div>
        </div>
        <div class="flex-1">
            <TrackList Tracks="@_queue" OnPlayTrack="OnPlay" />
        </div>
    </div>
</div>

@code {
    private readonly List<MediaMusic.Data.Models.Track> _queue = new();

    private void OnPlay(MediaMusic.Data.Models.Track t)
    {
        Lyrics.LoadForTrack(t.FilePath);
        Player.Play(t);
    }
}

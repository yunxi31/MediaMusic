    // Library operations
    private async Task AddFolder()
    {
        if (OperatingSystem.IsWindows())
        {
            var picked = FolderPicker.PickFolder();
            if (!string.IsNullOrWhiteSpace(picked) && !LibraryFolders.Contains(picked))
            {
                LibraryFolders.Add(picked);
                NewFolderInput = "";
                await SaveFoldersAsync();
                return;
            }
        }

        if (!string.IsNullOrWhiteSpace(NewFolderInput) && !LibraryFolders.Contains(NewFolderInput))
        {
            LibraryFolders.Add(NewFolderInput);
            NewFolderInput = "";
            await SaveFoldersAsync();
        }
    }

    private async Task RemoveFolder(string folder)
    {
        LibraryFolders.Remove(folder);
        await SaveFoldersAsync();
    }

    private async Task SaveFoldersAsync()
    {
        var json = JsonSerializer.Serialize(LibraryFolders);
        await Settings.SetAsync("scan_roots", json);
        AppState.ScanRoots.Clear();
        AppState.ScanRoots.AddRange(LibraryFolders);
    }

    // Appearance operations
    private async Task ChangeTheme(string theme)
    {
        ThemeName = theme;
        await Settings.SetAsync("theme", theme);

        // Apply theme directly via component-level IJSRuntime.
        // ThemeService is a Singleton but IJSRuntime is Scoped per-circuit,
        // so ThemeService's captured IJSRuntime may be stale / disconnected.
        // The component's injected JS is always the live circuit runtime.
        try
        {
            if (theme == "dark")
                await JS.InvokeVoidAsync("eval", "document.documentElement.classList.add('dark')");
            else
                await JS.InvokeVoidAsync("eval", "document.documentElement.classList.remove('dark')");
        }
        catch { }

        // Keep AppState in sync so other components reflect the theme change.
        AppState.SetTheme(theme);
    }

    // Chromeless window action helpers
    private async Task Minimize() => await JS.InvokeVoidAsync("mediamusic.window.minimize");
    private async Task Maximize() => await JS.InvokeVoidAsync("mediamusic.window.maximize");

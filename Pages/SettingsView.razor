    // Audio states
    private string OutputDevice = "System Default (WASAPI)";
    private int BufferSize = 512;
    private bool GaplessEnabled = true;
    private int CrossfadeDurationMs = 8;

    // Library states
    private List<string> LibraryFolders = new() { @"D:\LosslessMusic", @"C:\Users\Yunxi\Music" };
    private string NewFolderInput = "";

    // Appearance state
    private string ThemeName = "dark";

    // Shortcut states
    private bool GlobalHotkeysEnabled = true;
    private string ShortcutPlayPause = "Space";
    private string ShortcutNext = "Ctrl + Right";
    private string ShortcutPrev = "Ctrl + Left";
    private string ShortcutVolUp = "Alt + Up";
    private string ShortcutVolDown = "Alt + Down";
    private string ShortcutToggleMini = "Ctrl + M";
    
    private string recordingKey = "";

    protected override async Task OnInitializedAsync()
    {
        // Load Audio Settings
        OutputDevice = await Settings.GetAsync<string>("output_device", "System Default (WASAPI)") ?? "System Default (WASAPI)";
        BufferSize = await Settings.GetAsync<int>("buffer_size", 512);

        var gaplessVal = await Settings.GetAsync<string>("gapless_enabled", "true") ?? "true";
        GaplessEnabled = gaplessVal == "true";

        var crossfadeVal = await Settings.GetAsync<string>("crossfade_duration_ms", "8") ?? "8";
        if (int.TryParse(crossfadeVal, out var cf))
        {
            CrossfadeDurationMs = cf;
        }

        // Load Library Roots
        var rootsJson = await Settings.GetAsync("scan_roots");
        if (!string.IsNullOrEmpty(rootsJson))
        {
            try
            {
                var savedRoots = JsonSerializer.Deserialize<List<string>>(rootsJson);
                if (savedRoots != null && savedRoots.Count > 0)
                {
                    LibraryFolders = savedRoots;
                }
            }
            catch { }
        }

        // Load Theme
        ThemeName = await Settings.GetAsync<string>("theme", "dark") ?? "dark";

        // Load Hotkeys
        var globalHotkeysVal = await Settings.GetAsync("global_hotkeys_enabled", "true") ?? "true";
        GlobalHotkeysEnabled = globalHotkeysVal == "true";

        ShortcutPlayPause = await Settings.GetAsync("shortcut_play_pause", "Space") ?? "Space";
        ShortcutNext = await Settings.GetAsync("shortcut_next", "Ctrl + Right") ?? "Ctrl + Right";
        ShortcutPrev = await Settings.GetAsync("shortcut_prev", "Ctrl + Left") ?? "Ctrl + Left";
        ShortcutVolUp = await Settings.GetAsync("shortcut_vol_up", "Alt + Up") ?? "Alt + Up";
        ShortcutVolDown = await Settings.GetAsync("shortcut_vol_down", "Alt + Down") ?? "Alt + Down";
        ShortcutToggleMini = await Settings.GetAsync("shortcut_toggle_mini", "Ctrl + M") ?? "Ctrl + M";

        RegisterHotkeys();

        // Load Visualizer
        VisualizerStyle = await Settings.GetAsync<string>("visualizer_style", "classic_bars") ?? "classic_bars";
        VisualizerSensitivity = await Settings.GetAsync<int>("visualizer_sensitivity", 75);
        VisualizerDensity = await Settings.GetAsync<int>("visualizer_density", 68);
        VisualizerFullscreen = (await Settings.GetAsync<string>("visualizer_fullscreen", "true") ?? "true") == "true";
        VisualizerShowHz = (await Settings.GetAsync<string>("visualizer_show_hz", "false") ?? "false") == "true";
    }

    // Visualizer states
    private string VisualizerStyle = "classic_bars";
    private int VisualizerSensitivity = 75;
    private int VisualizerDensity = 68;
    private bool VisualizerFullscreen = true;
    private bool VisualizerShowHz = false;

    private readonly int[] ClassicBarsHeights = new[] { 20, 35, 70, 50, 40, 85, 45, 60, 80, 15, 30, 75, 45, 55, 35, 78, 52, 28, 70, 38, 20, 35, 70, 50 };

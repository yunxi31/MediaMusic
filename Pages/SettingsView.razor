    private void BackupDatabase()
    {
        try
        {
            var dbPath = Path.Combine(AppContext.BaseDirectory, "media_music.db");
            var backupPath = Path.Combine(AppContext.BaseDirectory, "media_music_backup.db");
            if (File.Exists(dbPath))
            {
                File.Copy(dbPath, backupPath, true);
                LastBackupTime = DateTime.Now.ToString("yyyy-MM-dd HH:mm");
                TerminalLines.Add(new TerminalLine { Text = $"> 数据库成功备份至: {backupPath} — {LastBackupTime}" });
            }
            else
            {
                TerminalLines.Add(new TerminalLine { Text = "警告: 未找到源数据库文件 media_music.db", IsWarning = true });
            }
        }
        catch (Exception ex)
        {
            TerminalLines.Add(new TerminalLine { Text = $"备份失败: {ex.Message}", IsError = true });
        }
        StateHasChanged();
    }

    private void RestoreBackup()
    {
        try
        {
            var dbPath = Path.Combine(AppContext.BaseDirectory, "media_music.db");
            var backupPath = Path.Combine(AppContext.BaseDirectory, "media_music_backup.db");
            if (File.Exists(backupPath))
            {
                File.Copy(backupPath, dbPath, true);
                TerminalLines.Add(new TerminalLine { Text = "> 已成功从备份文件恢复数据库。", IsWarning = true });
            }
            else
            {
                TerminalLines.Add(new TerminalLine { Text = "警告: 找不到有效备份文件 media_music_backup.db", IsWarning = true });
            }
        }
        catch (Exception ex)

@page "/settings"
@using MediaMusic.Services
@inject SettingsService Settings
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>设置 - MediaMusic</PageTitle>

<div class="settings-page">
    <div class="settings-header">
        <span class="header-title">设置</span>
    </div>

    <!-- Main settings area -->
    <div class="settings-body">
        <!-- Left Sidebar Navigation -->
        <div class="settings-sidebar @(IsSettingsSidebarCollapsed ? "collapsed" : "")">
            <div class="sidebar-header-row">
                @if (!IsSettingsSidebarCollapsed)
                {
                    <span class="sidebar-title-text">分类</span>
                }
                <button class="sidebar-toggle-btn" @onclick="ToggleSettingsSidebar" title="@(IsSettingsSidebarCollapsed ? "展开分类" : "收起分类")">
                    <svg class="w-4 h-4 transition-transform duration-200 @(IsSettingsSidebarCollapsed ? "rotate-180" : "")" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <rect x="3" y="4" width="18" height="16" rx="2" stroke-linejoin="round" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 4v16" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16 10l-3 2 3 2" />
                    </svg>
                </button>
            </div>

            <button class="sidebar-item @(ActiveTab == "audio" ? "active" : "")" @onclick='() => ActiveTab = "audio"' title="音频设置">
                <svg class="sidebar-item-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
                </svg>
                @if (!IsSettingsSidebarCollapsed)
                {
                    <span class="sidebar-item-text">音频设置</span>
                }
            </button>

            <button class="sidebar-item @(ActiveTab == "shortcuts" ? "active" : "")" @onclick='() => ActiveTab = "shortcuts"' title="快捷键">
                <svg class="sidebar-item-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
                </svg>
                @if (!IsSettingsSidebarCollapsed)
                {
                    <span class="sidebar-item-text">快捷键</span>
                }
            </button>

            <button class="sidebar-item @(ActiveTab == "library" ? "active" : "")" @onclick='() => ActiveTab = "library"' title="曲库管理">
                <svg class="sidebar-item-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />
                </svg>
                @if (!IsSettingsSidebarCollapsed)
                {
                    <span class="sidebar-item-text">曲库管理</span>
                }
            </button>

            <button class="sidebar-item @(ActiveTab == "appearance" ? "active" : "")" @onclick='() => ActiveTab = "appearance"' title="外观">
                <svg class="sidebar-item-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.01-1.712a15.9 15.9 0 001.671-2.757m0 0a3.001 3.001 0 014.056-4.056m-4.056 4.056a3.001 3.001 0 004.056-4.056M6.637 10.07l-.215-.338a.5.5 0 00-.696-.121L4.31 10.53a.5.5 0 00-.121.696l.215.338m5.313-1.493L13.12 6.84a1.5 1.5 0 012.122 0l2.918 2.918a1.5 1.5 0 010 2.122l-3.379 3.379m-3.379-3.379l3.379 3.379m0 0a3 3 0 01-4.243 4.243l-1.07-1.07" />
                </svg>
                @if (!IsSettingsSidebarCollapsed)
                {
                    <span class="sidebar-item-text">外观</span>
                }
            </button>

            <button class="sidebar-item @(ActiveTab == "about" ? "active" : "")" @onclick='() => ActiveTab = "about"' title="关于">
                <svg class="sidebar-item-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 00-.51-.98l-.04-.008a.75.75 0 00-.916.51l-.025.1a.75.75 0 00.51.916l.04.008a.75.75 0 00.916-.51l.025-.1zm.53 3.25a.75.75 0 00-1.5 0v3a.75.75 0 001.5 0v-3zM12 9a1 1 0 100-2 1 1 0 000 2zM21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                @if (!IsSettingsSidebarCollapsed)
                {
                    <span class="sidebar-item-text">关于</span>
                }
            </button>
        </div>

        <!-- Right Content Panels -->
        <div class="settings-panel">
            @if (ActiveTab == "audio")
            {
                <div class="panel-header">
                    <h2>音频设置 (Audio)</h2>
                </div>

                <div class="panel-content">
                    <!-- Output Device Dropdown -->
                    <div class="setting-group">
                        <label class="setting-label">Output Device</label>
                        <div class="custom-select-wrapper">
                            <select class="custom-select" value="@OutputDevice" @onchange="OnDeviceChange">
                                <option value="System Default (WASAPI)">System Default (WASAPI)</option>
                                <option value="Speakers (Realtek High Definition Audio)">Speakers (Realtek High Definition Audio)</option>
                                <option value="ASIO: Focusrite USB ASIO">ASIO: Focusrite USB ASIO</option>
                            </select>
                            <span class="select-arrow">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                </svg>
                            </span>
                        </div>
                    </div>

                    <!-- Buffer Size Slider -->
                    <div class="setting-group">
                        <div class="flex justify-between items-center mb-1">
                            <label class="setting-label">Buffer Size</label>
                            <span class="setting-value font-mono">@BufferSize Samples</span>
                        </div>
                        <div class="slider-wrapper">
                            @{
                                var bufferPercent = (BufferSize - 64) / (2048.0 - 64) * 100.0;
                            }
                            <div class="slider-track-fill" style="width: @(bufferPercent)%"></div>
                            <input type="range" min="64" max="2048" step="64" 
                                   class="range-slider" 
                                   value="@BufferSize" 
                                   @oninput="OnBufferSizeInput" 
                                   @onchange="SaveBufferSize" />
                        </div>
                        <div class="slider-labels">
                            <span>Low Latency</span>
                            <span>High Stability</span>
                        </div>
                    </div>

                    <!-- Spacer Line -->
                    <div class="divider"></div>

                    <!-- Gapless Playback Switch -->
                    <div class="setting-group flex items-center justify-between py-2">
                        <div class="flex-1 pr-4">
                            <label class="setting-label block mb-0.5">Gapless Playback</label>
                            <span class="setting-description">Eliminate silence between consecutive tracks</span>
                        </div>
                        <button class="toggle-switch @(GaplessEnabled ? "on" : "")" @onclick="ToggleGapless" title="切换无缝播放">
                            <span class="toggle-thumb"></span>
                        </button>
                    </div>

                    <!-- Crossfade Duration Number Input -->
                    <div class="setting-group flex items-center justify-between py-2">
                        <div class="flex-1 pr-4">
                            <label class="setting-label block mb-0.5">Crossfade Duration</label>
                            <span class="setting-description">Overlap tracks during transition</span>
                        </div>
                        <div class="number-input-wrapper">
                            <input type="number" min="0" max="10000" step="100"
                                   class="number-input" 
                                   value="@CrossfadeDurationMs" 
                                   @oninput="OnCrossfadeInput" 
                                   @onchange="SaveCrossfade" />
                            <span class="input-suffix">ms</span>
                        </div>
                    </div>
                </div>
            }
            else if (ActiveTab == "shortcuts")
            {
                <div class="panel-header shortcuts-header">
                    <h2>快捷键配置 (Shortcuts)</h2>
                    <p class="panel-subtitle">自定义您的高保真音频工作流。全局快捷键允许在 MediaMusic 后台运行时进行控制。</p>
                </div>
                
                <div class="panel-content shortcuts-panel-content">
                    <!-- Global Hotkeys Card -->
                    <div class="global-hotkeys-card">
                        <div class="card-left">
                            <div class="keyboard-icon-container">
                                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="2" y="4" width="20" height="16" rx="2" ry="2" />
                                    <line x1="6" y1="8" x2="6.01" y2="8" />
                                    <line x1="10" y1="8" x2="10.01" y2="8" />
                                    <line x1="14" y1="8" x2="14.01" y2="8" />
                                    <line x1="18" y1="8" x2="18.01" y2="8" />
                                    <line x1="6" y1="12" x2="6.01" y2="12" />
                                    <line x1="18" y1="12" x2="18.01" y2="12" />
                                    <rect x="6" y="16" width="12" height="2" rx="0.5" />
                                    <line x1="10" y1="12" x2="14" y2="12" />
                                </svg>
                            </div>
                            <div class="card-info">
                                <span class="card-title">启用全局快捷键 (Enable Global Hotkeys)</span>
                                <span class="card-description">允许MediaMusic拦截操作系统中的快捷键命令。</span>
                            </div>
                        </div>
                        <div class="card-right">
                            <button class="toggle-switch @(GlobalHotkeysEnabled ? "on" : "")" @onclick="ToggleGlobalHotkeys" title="启用全局快捷键">
                                <span class="toggle-thumb"></span>
                            </button>
                        </div>
                    </div>

                    <!-- Playback Controls -->
                    <div class="shortcuts-section">
                        <div class="section-title-row">
                            <span class="section-icon">
                                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <circle cx="12" cy="12" r="3" fill="currentColor"></circle>
                                </svg>
                            </span>
                            <span class="section-title">播放控制 (Playback Controls)</span>
                            <div class="section-divider"></div>
                        </div>
                        
                        <div class="shortcut-cards-grid">
                            <div class="shortcut-card @(recordingKey == "play_pause" ? "recording" : "")" tabindex="0" @onclick='() => StartRecording("play_pause")' @onkeydown="HandleKeyDown">
                                <div class="card-label-area">
                                    <span class="shortcut-icon">
                                        <svg class="shortcut-icon-svg" viewBox="0 0 24 24" fill="currentColor">
                                            <path d="M6 19h3V5H6v14zm5-14v14l9-7-9-7z"/>
                                        </svg>
                                    </span>
                                    <span class="shortcut-name">播放 / 暂停</span>
                                </div>
                                <div class="shortcut-keys-area">
                                    @if (recordingKey == "play_pause")
                                    {
                                        <span class="recording-prompt">请按下快捷键...</span>
                                    }
                                    else
                                    {
                                        @foreach (var key in SplitKeys(ShortcutPlayPause))
                                        {
                                            <span class="key-cap">@key</span>
                                            @if (key != SplitKeys(ShortcutPlayPause).Last())
                                            {
                                                <span class="key-plus">+</span>
                                            }
                                        }
                                    }
                                </div>
                            </div>

                            <div class="shortcut-card @(recordingKey == "next" ? "recording" : "")" tabindex="0" @onclick='() => StartRecording("next")' @onkeydown="HandleKeyDown">
                                <div class="card-label-area">
                                    <span class="shortcut-icon">
                                        <svg class="shortcut-icon-svg" viewBox="0 0 24 24" fill="currentColor">
                                            <path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/>
                                        </svg>
                                    </span>
                                    <span class="shortcut-name">下一首</span>
                                </div>
                                <div class="shortcut-keys-area">
                                    @if (recordingKey == "next")
                                    {
                                        <span class="recording-prompt">请按下快捷键...</span>
                                    }
                                    else
                                    {
                                        @foreach (var key in SplitKeys(ShortcutNext))
                                        {
                                            <span class="key-cap">@key</span>
                                            @if (key != SplitKeys(ShortcutNext).Last())
                                            {
                                                <span class="key-plus">+</span>
                                            }
                                        }
                                    }
                                </div>
                            </div>

                            <div class="shortcut-card @(recordingKey == "prev" ? "recording" : "")" tabindex="0" @onclick='() => StartRecording("prev")' @onkeydown="HandleKeyDown">
                                <div class="card-label-area">
                                    <span class="shortcut-icon">
                                        <svg class="shortcut-icon-svg" viewBox="0 0 24 24" fill="currentColor">
                                            <path d="M11.5 12L20 18V6l-8.5 6zM6 6h2v12H6V6z"/>
                                        </svg>
                                    </span>
                                    <span class="shortcut-name">上一首</span>
                                </div>
                                <div class="shortcut-keys-area">
                                    @if (recordingKey == "prev")
                                    {
                                        <span class="recording-prompt">请按下快捷键...</span>
                                    }
                                    else
                                    {
                                        @foreach (var key in SplitKeys(ShortcutPrev))
                                        {
                                            <span class="key-cap">@key</span>
                                            @if (key != SplitKeys(ShortcutPrev).Last())
                                            {
                                                <span class="key-plus">+</span>
                                            }
                                        }
                                    }
                                </div>
                            </div>
                            
                            <div class="shortcut-card-empty"></div>
                        </div>
                    </div>

                    <!-- System Controls -->
                    <div class="shortcuts-section">
                        <div class="section-title-row">
                            <span class="section-icon">
                                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="3" width="18" height="18" rx="2" />
                                    <line x1="9" y1="3" x2="9" y2="21" />
                                    <line x1="15" y1="3" x2="15" y2="21" />
                                </svg>
                            </span>
                            <span class="section-title">系统控制 (System Controls)</span>
                            <div class="section-divider"></div>
                        </div>
                        
                        <div class="shortcut-cards-grid">
                            <div class="shortcut-card @(recordingKey == "vol_up" ? "recording" : "")" tabindex="0" @onclick='() => StartRecording("vol_up")' @onkeydown="HandleKeyDown">
                                <div class="card-label-area">
                                    <span class="shortcut-icon">
                                        <svg class="shortcut-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" fill="currentColor"></polygon>
                                            <line x1="16" y1="12" x2="22" y2="12"></line>
                                            <line x1="19" y1="9" x2="19" y2="15"></line>
                                        </svg>
                                    </span>
                                    <span class="shortcut-name">音量增大</span>
                                </div>
                                <div class="shortcut-keys-area">
                                    @if (recordingKey == "vol_up")
                                    {
                                        <span class="recording-prompt">请按下快捷键...</span>
                                    }
                                    else
                                    {
                                        @foreach (var key in SplitKeys(ShortcutVolUp))
                                        {
                                            <span class="key-cap">@key</span>
                                            @if (key != SplitKeys(ShortcutVolUp).Last())
                                            {
                                                <span class="key-plus">+</span>
                                            }
                                        }
                                    }
                                </div>
                            </div>

                            <div class="shortcut-card @(recordingKey == "vol_down" ? "recording" : "")" tabindex="0" @onclick='() => StartRecording("vol_down")' @onkeydown="HandleKeyDown">
                                <div class="card-label-area">
                                    <span class="shortcut-icon">
                                        <svg class="shortcut-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" fill="currentColor"></polygon>
                                            <line x1="16" y1="12" x2="22" y2="12"></line>
                                        </svg>
                                    </span>
                                    <span class="shortcut-name">音量减小</span>
                                </div>
                                <div class="shortcut-keys-area">
                                    @if (recordingKey == "vol_down")
                                    {
                                        <span class="recording-prompt">请按下快捷键...</span>
                                    }
                                    else
                                    {
                                        @foreach (var key in SplitKeys(ShortcutVolDown))
                                        {
                                            <span class="key-cap">@key</span>
                                            @if (key != SplitKeys(ShortcutVolDown).Last())
                                            {
                                                <span class="key-plus">+</span>
                                            }
                                        }
                                    }
                                </div>
                            </div>

                            <div class="shortcut-card @(recordingKey == "toggle_mini" ? "recording" : "")" tabindex="0" @onclick='() => StartRecording("toggle_mini")' @onkeydown="HandleKeyDown">
                                <div class="card-label-area">
                                    <span class="shortcut-icon">
                                        <svg class="shortcut-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                            <rect x="12" y="12" width="7" height="7" rx="1" ry="1" fill="currentColor"></rect>
                                        </svg>
                                    </span>
                                    <span class="shortcut-name">切换迷你播放器</span>
                                </div>
                                <div class="shortcut-keys-area">
                                    @if (recordingKey == "toggle_mini")
                                    {
                                        <span class="recording-prompt">请按下快捷键...</span>
                                    }
                                    else
                                    {
                                        @foreach (var key in SplitKeys(ShortcutToggleMini))
                                        {
                                            <span class="key-cap">@key</span>
                                            @if (key != SplitKeys(ShortcutToggleMini).Last())
                                            {
                                                <span class="key-plus">+</span>
                                            }
                                        }
                                    }
                                </div>
                            </div>
                            
                            <div class="shortcut-card-empty"></div>
                        </div>
                    </div>

                    <!-- Reset Row -->
                    <div class="reset-row">
                        <button class="reset-btn" @onclick="ResetShortcutsToDefault">
                            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67" />
                            </svg>
                            恢复默认 (Reset to Default)
                        </button>
                    </div>
                </div>
            }
            else if (ActiveTab == "library")
            {
                <div class="panel-header">
                    <h2>曲库管理 (Library)</h2>
                </div>
                <div class="panel-content">
                    <p class="text-xs text-neutral-500 mb-4">指定播放器扫描本地无损音频的文件夹路径。</p>
                    
                    <div class="folder-list mb-4">
                        @foreach (var folder in LibraryFolders)
                        {
                            <div class="folder-item">
                                <span class="folder-path text-xs text-neutral-200">@folder</span>
                                <button class="folder-remove-btn" @onclick="() => RemoveFolder(folder)">
                                    <svg class="w-4 h-4 text-neutral-500 hover:text-red-500 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                </button>
                            </div>
                        }
                    </div>

                    <div class="flex gap-2">
                        <input type="text" class="folder-input text-xs text-white" placeholder="输入文件夹路径..." @bind="NewFolderInput" />
                        <button class="folder-add-btn text-xs" @onclick="AddFolder">添加目录</button>
                    </div>
                </div>
            }
            else if (ActiveTab == "appearance")
            {
                <div class="panel-header">
                    <h2>外观 (Appearance)</h2>
                </div>
                <div class="panel-content">
                    <p class="text-xs text-neutral-500 mb-6">管理软件的界面风格及主题切换。</p>
                    <div class="theme-selection">
                        <label class="setting-label block mb-3">界面主题</label>
                        <div class="theme-grid">
                            <div class="theme-card @(ThemeName == "dark" ? "active" : "")" @onclick='() => ChangeTheme("dark")'>
                                <div class="theme-preview bg-[#0d0d12]">
                                    <div class="preview-bar bg-white/5 w-full h-2"></div>
                                    <div class="preview-body flex flex-1 w-full gap-1 p-1">
                                        <div class="w-2 bg-white/5 h-full rounded-sm"></div>
                                        <div class="flex-1 bg-white/2 h-full rounded-sm"></div>
                                    </div>
                                </div>
                                <span class="theme-label">AMOLED 深色</span>
                            </div>
                            <div class="theme-card @(ThemeName == "light" ? "active" : "")" @onclick='() => ChangeTheme("light")'>
                                <div class="theme-preview bg-[#f4f4f5]">
                                    <div class="preview-bar bg-black/5 w-full h-2"></div>
                                    <div class="preview-body flex flex-1 w-full gap-1 p-1">
                                        <div class="w-2 bg-black/5 h-full rounded-sm"></div>
                                        <div class="flex-1 bg-black/2 h-full rounded-sm"></div>
                                    </div>
                                </div>
                                <span class="theme-label">极致浅色</span>
                            </div>
                        </div>
                    </div>
                </div>
            }

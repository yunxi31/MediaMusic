        Hotkeys.SetEnabled(GlobalHotkeysEnabled);
    }

    private async Task StartRecording(string key)
    {
        recordingKey = key;
        await JS.InvokeVoidAsync("mediamusic.setRecording", true);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (string.IsNullOrEmpty(recordingKey)) return;

        if (e.Key == "Control" || e.Key == "Shift" || e.Key == "Alt" || e.Key == "Meta")
            return;

        if (e.Key == "Escape")
        {
            recordingKey = "";
            await JS.InvokeVoidAsync("mediamusic.setRecording", false);
            return;
        }

        var parts = new List<string>();
        if (e.CtrlKey) parts.Add("Ctrl");
        if (e.AltKey) parts.Add("Alt");
        if (e.ShiftKey) parts.Add("Shift");

        var mainKey = e.Key;
        if (mainKey == " ") mainKey = "Space";
        else if (mainKey == "ArrowUp") mainKey = "Up";
        else if (mainKey == "ArrowDown") mainKey = "Down";
        else if (mainKey == "ArrowLeft") mainKey = "Left";
        else if (mainKey == "ArrowRight") mainKey = "Right";
        else if (mainKey.Length == 1) mainKey = mainKey.ToUpper();

        parts.Add(mainKey);
        var combination = string.Join(" + ", parts);

        var captured = recordingKey;
        recordingKey = "";
        await JS.InvokeVoidAsync("mediamusic.setRecording", false);
        await SaveShortcut(captured, combination);
    }

    private async Task SaveShortcut(string keyType, string combination)
    {
        switch (keyType)
        {
            case "play_pause":
                ShortcutPlayPause = combination;
                await Settings.SetAsync("shortcut_play_pause", combination);
                break;
            case "next":
                ShortcutNext = combination;
                await Settings.SetAsync("shortcut_next", combination);
                break;
            case "prev":
                ShortcutPrev = combination;
                await Settings.SetAsync("shortcut_prev", combination);
                break;
            case "vol_up":
                ShortcutVolUp = combination;
                await Settings.SetAsync("shortcut_vol_up", combination);
                break;
            case "vol_down":
                ShortcutVolDown = combination;
                await Settings.SetAsync("shortcut_vol_down", combination);
                break;
            case "toggle_mini":
                ShortcutToggleMini = combination;
                await Settings.SetAsync("shortcut_toggle_mini", combination);
                break;
        }
        RegisterHotkeys();
    }

    private void RegisterHotkeys()
    {
        WindowHelper.RegisterShortcut("play_pause", ShortcutPlayPause);
        WindowHelper.RegisterShortcut("next", ShortcutNext);
        WindowHelper.RegisterShortcut("prev", ShortcutPrev);
        WindowHelper.RegisterShortcut("vol_up", ShortcutVolUp);
        WindowHelper.RegisterShortcut("vol_down", ShortcutVolDown);

        if (!OperatingSystem.IsWindows()) return;
        try
        {
            Hotkeys.SetEnabled(GlobalHotkeysEnabled);
            if (GlobalHotkeysEnabled)
            {
                Hotkeys.Register("play_pause", ShortcutPlayPause, () => Player.TogglePlayPause());
                Hotkeys.Register("next", ShortcutNext, () => Player.Next());
                Hotkeys.Register("prev", ShortcutPrev, () => Player.Previous());
                Hotkeys.Register("vol_up", ShortcutVolUp, () => Player.SetVolume(Math.Min(1.0f, Player.State.Volume + 0.05f)));
                Hotkeys.Register("vol_down", ShortcutVolDown, () => Player.SetVolume(Math.Max(0.0f, Player.State.Volume - 0.05f)));
            }
        }
        catch { }
    }

    private async Task ResetShortcutsToDefault()
    {
        GlobalHotkeysEnabled = true;
        ShortcutPlayPause = "Space";
        ShortcutNext = "Ctrl + Right";
        ShortcutPrev = "Ctrl + Left";
        ShortcutVolUp = "Alt + Up";
        ShortcutVolDown = "Alt + Down";
        ShortcutToggleMini = "Ctrl + M";

        await Settings.SetAsync("global_hotkeys_enabled", "true");
        await Settings.SetAsync("shortcut_play_pause", "Space");
        await Settings.SetAsync("shortcut_next", "Ctrl + Right");
        await Settings.SetAsync("shortcut_prev", "Ctrl + Left");
        await Settings.SetAsync("shortcut_vol_up", "Alt + Up");
        await Settings.SetAsync("shortcut_vol_down", "Alt + Down");
        await Settings.SetAsync("shortcut_toggle_mini", "Ctrl + M");


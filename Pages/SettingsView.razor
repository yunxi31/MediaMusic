        }
        StateHasChanged();
    }

    private async Task RunMetadataScan()
    {
        if (IsScanning) return;
        IsScanning = true;
        TerminalLines.Clear();
        TerminalLines.Add(new TerminalLine { Text = "> 初始化深度曲库扫描..." });
        StateHasChanged();

        var validFolders = LibraryFolders.Where(Directory.Exists).ToList();
        if (!validFolders.Any())
        {
            TerminalLines.Add(new TerminalLine { Text = "警告: 未配置文件路径或配置路径不存在。", IsWarning = true });
            IsScanning = false;
            StateHasChanged();
            return;
        }

        TerminalLines.Add(new TerminalLine { Text = $"> 准备扫描 {validFolders.Count} 个根目录..." });
        StateHasChanged();

        var progress = new Progress<ScanProgress>(p =>
        {
            if (p.Processed % 5 == 0 || p.Processed == p.TotalFound)
            {
                TerminalLines.Add(new TerminalLine { Text = $"> [处理中] ({p.Processed}/{p.TotalFound}) {Path.GetFileName(p.CurrentFile)}" });
                StateHasChanged();
            }
        });

        try
        {
            await Library.ScanAsync(validFolders, progress);
            TerminalLines.Add(new TerminalLine { Text = "> 扫描完成，数据库已成功刷新并建立索引。" });
        }
        catch (Exception ex)
        {
            TerminalLines.Add(new TerminalLine { Text = $"错误: 扫描过程中发生异常 — {ex.Message}", IsError = true });
        }
        finally
        {
            IsScanning = false;
            StateHasChanged();
        }
    }


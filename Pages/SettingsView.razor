    // ── Advanced Management ──────────────────────────────────────────────
    private string LastBackupTime = "尚未备份";
    private bool IsScanning = false;
    private List<TerminalLine> TerminalLines = new();

    private class TerminalLine
    {
        public string Text { get; set; } = "";
        public bool IsError { get; set; }
        public bool IsWarning { get; set; }
    }

    private async Task ExportM3U()
    {
        try
        {
            TerminalLines.Add(new TerminalLine { Text = "> 正在从 SQLite 数据库提取音轨数据..." });
            StateHasChanged();
            var tracks = (await TrackRepo.SearchAsync(null, null, null, null)).ToList();
            var desktop = Environment.GetFolderPath(Environment.SpecialFolder.DesktopDirectory);
            var filePath = Path.Combine(desktop, "MediaMusic_Export.m3u");

            using var writer = new StreamWriter(filePath, false, System.Text.Encoding.UTF8);
            writer.WriteLine("#EXTM3U");
            foreach (var t in tracks)
            {
                var sec = (int)((t.DurationMs ?? 0) / 1000);
                writer.WriteLine($"#EXTINF:{sec},{t.ArtistName} - {t.Title}");
                writer.WriteLine(t.FilePath);
            }

            TerminalLines.Add(new TerminalLine { Text = $"> 已成功导出 {tracks.Count} 首音轨至桌面: {filePath}" });
        }
        catch (Exception ex)
        {
            TerminalLines.Add(new TerminalLine { Text = $"导出 M3U 失败: {ex.Message}", IsError = true });
        }
        StateHasChanged();
    }


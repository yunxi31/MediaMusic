@code {
    private string ActiveTab = "audio";
    private bool IsSettingsSidebarCollapsed = false;

    private void ToggleSettingsSidebar()
    {
        IsSettingsSidebarCollapsed = !IsSettingsSidebarCollapsed;
    }

    // Audio states
    private string OutputDevice = "System Default (WASAPI)";
    private int BufferSize = 512;
    private bool GaplessEnabled = true;
    private int CrossfadeDurationMs = 8; // Defaulting to 8ms matching Figma spec

    // Library states
    private List<string> LibraryFolders = new() { @"D:\LosslessMusic", @"C:\Users\Yunxi\Music" };
    private string NewFolderInput = "";

    // Appearance state
    private string ThemeName = "dark";

    // Shortcut states
    private bool GlobalHotkeysEnabled = true;
    private string ShortcutPlayPause = "Space";
    private string ShortcutNext = "Ctrl + Right";
    private string ShortcutPrev = "Ctrl + Left";
    private string ShortcutVolUp = "Alt + Up";
    private string ShortcutVolDown = "Alt + Down";
    private string ShortcutToggleMini = "Ctrl + M";
    
    private string recordingKey = "";

    protected override async Task OnInitializedAsync()
    {
        // Load Settings
        OutputDevice = await Settings.GetAsync<string>("output_device", "System Default (WASAPI)") ?? "System Default (WASAPI)";
        BufferSize = await Settings.GetAsync<int>("buffer_size", 512);

        var gaplessVal = await Settings.GetAsync<string>("gapless_enabled", "true") ?? "true";
        GaplessEnabled = gaplessVal == "true";

        var crossfadeVal = await Settings.GetAsync<string>("crossfade_duration_ms", "8") ?? "8";
        if (int.TryParse(crossfadeVal, out var cf))
        {
            CrossfadeDurationMs = cf;
        }

        ThemeName = await Settings.GetAsync<string>("theme", "dark") ?? "dark";

        var globalHotkeysVal = await Settings.GetAsync("global_hotkeys_enabled", "true") ?? "true";
        GlobalHotkeysEnabled = globalHotkeysVal == "true";

        ShortcutPlayPause = await Settings.GetAsync("shortcut_play_pause", "Space") ?? "Space";
        ShortcutNext = await Settings.GetAsync("shortcut_next", "Ctrl + Right") ?? "Ctrl + Right";
        ShortcutPrev = await Settings.GetAsync("shortcut_prev", "Ctrl + Left") ?? "Ctrl + Left";
        ShortcutVolUp = await Settings.GetAsync("shortcut_vol_up", "Alt + Up") ?? "Alt + Up";
        ShortcutVolDown = await Settings.GetAsync("shortcut_vol_down", "Alt + Down") ?? "Alt + Down";
        ShortcutToggleMini = await Settings.GetAsync("shortcut_toggle_mini", "Ctrl + M") ?? "Ctrl + M";
    }

    private async Task OnDeviceChange(ChangeEventArgs e)
    {
        if (e.Value != null)
        {
            OutputDevice = e.Value.ToString() ?? "System Default (WASAPI)";
            await Settings.SetAsync("output_device", OutputDevice);
        }
    }

    private void OnBufferSizeInput(ChangeEventArgs e)
    {
        if (e.Value != null && int.TryParse(e.Value.ToString(), out var size))
        {
            BufferSize = size;
        }
    }

    private async Task SaveBufferSize()
    {
        await Settings.SetAsync("buffer_size", BufferSize.ToString());
    }

    private async Task ToggleGapless()
    {
        GaplessEnabled = !GaplessEnabled;
        await Settings.SetAsync("gapless_enabled", GaplessEnabled ? "true" : "false");
    }

    private void OnCrossfadeInput(ChangeEventArgs e)
    {
        if (e.Value != null && int.TryParse(e.Value.ToString(), out var ms))
        {
            CrossfadeDurationMs = ms;
        }
    }

    private async Task SaveCrossfade()
    {
        await Settings.SetAsync("crossfade_duration_ms", CrossfadeDurationMs.ToString());
    }

    // Library operations
    private void AddFolder()
    {
        if (!string.IsNullOrWhiteSpace(NewFolderInput) && !LibraryFolders.Contains(NewFolderInput))
        {
            LibraryFolders.Add(NewFolderInput);
            NewFolderInput = "";
        }
    }

    private void RemoveFolder(string folder)
    {
        LibraryFolders.Remove(folder);
    }

    // Appearance operations
    private async Task ChangeTheme(string theme)
    {
        ThemeName = theme;
        await Settings.SetAsync("theme", theme);
        // Force ThemeService application if injected, for live visual testing
    }

    // Chromeless window action helpers
    private async Task Minimize() => await JS.InvokeVoidAsync("mediamusic.window.minimize");
    private async Task Maximize() => await JS.InvokeVoidAsync("mediamusic.window.maximize");
    private async Task Close() => await JS.InvokeVoidAsync("mediamusic.window.close");

    private async Task ToggleGlobalHotkeys()
    {
        GlobalHotkeysEnabled = !GlobalHotkeysEnabled;
        await Settings.SetAsync("global_hotkeys_enabled", GlobalHotkeysEnabled ? "true" : "false");
    }

    private void StartRecording(string key)
    {
        recordingKey = key;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (string.IsNullOrEmpty(recordingKey)) return;

        // Ignore modifier keys alone
        if (e.Key == "Control" || e.Key == "Shift" || e.Key == "Alt" || e.Key == "Meta")
            return;

        if (e.Key == "Escape")
        {
            recordingKey = "";
            return;
        }

        // Build key combination string
        var parts = new List<string>();
        if (e.CtrlKey) parts.Add("Ctrl");
        if (e.AltKey) parts.Add("Alt");
        if (e.ShiftKey) parts.Add("Shift");

        // Format key name nicely
        var mainKey = e.Key;
        if (mainKey == " ") mainKey = "Space";
        else if (mainKey == "ArrowUp") mainKey = "Up";
        else if (mainKey == "ArrowDown") mainKey = "Down";
        else if (mainKey == "ArrowLeft") mainKey = "Left";
        else if (mainKey == "ArrowRight") mainKey = "Right";
        else if (mainKey.Length == 1) mainKey = mainKey.ToUpper();

        parts.Add(mainKey);

        var combination = string.Join(" + ", parts);

        // Update state and save
        await SaveShortcut(recordingKey, combination);
        recordingKey = "";
    }

    private async Task SaveShortcut(string keyType, string combination)
    {
        switch (keyType)
        {
            case "play_pause":
                ShortcutPlayPause = combination;
                await Settings.SetAsync("shortcut_play_pause", combination);
                break;
            case "next":
                ShortcutNext = combination;
                await Settings.SetAsync("shortcut_next", combination);
                break;
            case "prev":
                ShortcutPrev = combination;
                await Settings.SetAsync("shortcut_prev", combination);
                break;
            case "vol_up":
                ShortcutVolUp = combination;
                await Settings.SetAsync("shortcut_vol_up", combination);
                break;
            case "vol_down":
                ShortcutVolDown = combination;
                await Settings.SetAsync("shortcut_vol_down", combination);
                break;
            case "toggle_mini":
                ShortcutToggleMini = combination;
                await Settings.SetAsync("shortcut_toggle_mini", combination);
                break;
        }
    }

    private async Task ResetShortcutsToDefault()
    {
        GlobalHotkeysEnabled = true;
        ShortcutPlayPause = "Space";
        ShortcutNext = "Ctrl + Right";
        ShortcutPrev = "Ctrl + Left";
        ShortcutVolUp = "Alt + Up";
        ShortcutVolDown = "Alt + Down";
        ShortcutToggleMini = "Ctrl + M";

        await Settings.SetAsync("global_hotkeys_enabled", "true");
        await Settings.SetAsync("shortcut_play_pause", "Space");
        await Settings.SetAsync("shortcut_next", "Ctrl + Right");
        await Settings.SetAsync("shortcut_prev", "Ctrl + Left");
        await Settings.SetAsync("shortcut_vol_up", "Alt + Up");
        await Settings.SetAsync("shortcut_vol_down", "Alt + Down");
        await Settings.SetAsync("shortcut_toggle_mini", "Ctrl + M");
    }

    private List<string> SplitKeys(string shortcut)
    {
        if (string.IsNullOrEmpty(shortcut)) return new List<string>();
        return shortcut.Split(new[] { " + " }, StringSplitOptions.RemoveEmptyEntries).ToList();
    }
}


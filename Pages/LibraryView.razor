@page "/library"
@inject LibraryService Library
@inject PlayerService Player
@inject TrackRepository TrackRepo
@inject IJSRuntime JS
@inject AppState AppState
@implements IDisposable

<PageTitle>音乐库 - MediaMusic</PageTitle>

<div class="library-page">
    @* ─── Header Section ─── *@
    <div class="library-header">
        <div class="header-titles">
            <h1 class="library-title">音乐库</h1>
            <p class="library-subtitle">
                @if (_trackCount > 0)
                {
                    @($"{_results.Select(t => t.AlbumTitle).Distinct().Count():N0} 张专辑 • {FormatSize(_totalSize)} 无损音频")
                }
                else
                {
                    @("1,492 张专辑 • 14.2 TB 无损音频")
                }
            </p>
        </div>
        <div class="header-actions">
            <div class="search-box">
                <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" 
                       placeholder="搜索歌曲、艺术家、专辑..." 
                       value="@_searchQuery" 
                       @oninput="OnSearchInput" 
                       class="search-input" />
                @if (!string.IsNullOrEmpty(_searchQuery))
                {
                    <button class="clear-btn" @onclick="ClearSearch">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="18" y1="6" x2="6" y2="18"></line>
                            <line x1="6" y1="6" x2="18" y2="18"></line>
                        </svg>
                    </button>
                }
            </div>
            <button class="action-btn" @onclick="ToggleFilter">
                <svg class="action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <path d="M3 6h18M6 12h12M10 18h4" />
                </svg>
                筛选
            </button>
            <button class="action-btn" @onclick="ToggleSort">
                <svg class="action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <path d="M3 6h18M6 12h12M10 18h4" />
                </svg>
                添加日期
            </button>
        </div>
    </div>

    @* ─── Drag & Drop / Import Zone ─── *@
    <div class="import-zone" @onclick="PickAndScan">
        <div class="import-icon-circle">
            <svg class="import-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14 2 14 8 20 8" />
                <line x1="12" y1="18" x2="12" y2="12" />
                <polyline points="9 15 12 12 15 15" />
            </svg>
        </div>
        <h2 class="import-title">导入高解析音频源</h2>
        <p class="import-subtitle">将文件夹拖拽至此 (FLAC, ALAC, 或 WAV)。</p>
    </div>

    @* ─── Scan Progress ─── *@
    @if (_isScanning && AppState.ScanProgress is not null)
    {
        <div class="scan-progress-container">
            <div class="progress-bar-bg">
                <div class="progress-bar-fill" style="width:@(AppState.ScanProgress.TotalFound > 0 ? AppState.ScanProgress.Processed * 100 / AppState.ScanProgress.TotalFound : 0)%"></div>
            </div>
            <span class="progress-text">正在扫描: @AppState.ScanProgress.Processed / @AppState.ScanProgress.TotalFound</span>
        </div>
    }

    @* ─── Recently Added Section ─── *@
    <div class="recently-added-section">
        <div class="section-title-wrapper">
            <h2 class="section-title">最近添加</h2>
            <div class="section-divider"></div>
        </div>

        <div class="album-grid">
            @if (_results.Count > 0)
            {
                @foreach (var track in _results.Take(20))
                {
                    var isPlaying = Player.State.CurrentTrack != null && Player.State.CurrentTrack.Id == track.Id && Player.State.IsPlaying;
                    <div class="album-card" @onclick="() => OnPlay(track)">
                        <div class="album-cover-wrapper">
                            @if (!string.IsNullOrEmpty(track.CoverPath))
                            {
                                <img src="@track.CoverPath" alt="@track.Title" class="album-cover-img" />
                            }
                            else
                            {
                                <div class="album-cover-fallback">
                                    <svg class="fallback-note-icon" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M12 3v10.55A4 4 0 1 0 14 17V7h4V3h-6z" />
                                    </svg>
                                </div>
                            }

                            @* Quality badge *@
                            @if (track.SampleRate > 0 || !string.IsNullOrEmpty(track.Format))
                            {
                                <div class="quality-badge">
                                    @(track.BitRate > 0 ? $"{(track.BitRate > 1000 ? track.BitRate / 1000 : track.BitRate)}k" : track.Format?.ToUpper())
                                    @(track.SampleRate > 0 ? $"/{track.SampleRate / 1000}kHz" : "")
                                </div>
                            }

                            @* Play overlay *@
                            <div class="play-overlay">
                                <div class="play-btn-circle">
                                    @if (isPlaying)
                                    {
                                        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
                                    }
                                    else
                                    {
                                        <svg class="w-5 h-5 fill-current ml-0.5" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                    }
                                </div>
                            </div>
                        </div>
                        <h3 class="album-title">@(track.Title ?? "未知标题")</h3>
                        <p class="album-artist">@(track.ArtistName ?? "未知艺术家")</p>
                    </div>
                }
            }
            else if (_trackCount > 0 && !string.IsNullOrEmpty(_searchQuery))
            {
                <div class="search-empty-state">
                    <svg class="empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <circle cx="11" cy="11" r="8"></circle>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        <line x1="8" y1="11" x2="14" y2="11"></line>
                    </svg>
                    <p class="empty-title">未找到匹配的音乐</p>
                    <p class="empty-subtitle">尝试换个关键词，例如歌手名、专辑名或歌曲名</p>
                </div>
            }
            else
            {
                @foreach (var album in MockAlbums)
                {
                    var isPlaying = Player.State.CurrentTrack != null && Player.State.CurrentTrack.Title == album.Title && Player.State.IsPlaying;
                    <div class="album-card" @onclick="() => PlayMockAlbum(album)">
                        <div class="album-cover-wrapper">
                            <div class="album-cover-fallback @album.CoverClass">
                                @if (album.CoverClass == "cover-prismatic")
                                {
                                    <div class="prism-shape"></div>
                                    <div class="prism-glow"></div>
                                }
                                else if (album.CoverClass == "cover-industrial")
                                {
                                    <div class="neon-line"></div>
                                }
                                else if (album.CoverClass == "cover-void")
                                {
                                    <div class="void-circle"></div>
                                }
                                else if (album.CoverClass == "cover-analog")
                                {
                                    <div class="synth-knobs">
                                        <div class="synth-knob"></div>
                                        <div class="synth-knob"></div>
                                        <div class="synth-knob"></div>
                                    </div>
                                    <div class="synth-keys">
                                        <div class="synth-key"></div>
                                        <div class="synth-key"></div>
                                        <div class="synth-key"></div>
                                        <div class="synth-key"></div>
                                        <div class="synth-key"></div>
                                    </div>
                                }
                            </div>

                            @* Quality badge *@
                            <div class="quality-badge">
                                @album.Badge
                            </div>

                            @* Play overlay *@
                            <div class="play-overlay">
                                <div class="play-btn-circle">
                                    @if (isPlaying)
                                    {
                                        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
                                    }
                                    else
                                    {
                                        <svg class="w-5 h-5 fill-current ml-0.5" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                    }
                                </div>
                            </div>
                        </div>
                        <h3 class="album-title">@album.Title</h3>
                        <p class="album-artist">@album.Artist</p>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    private string? _searchQuery;
    private List<Track> _results = new();
    private int _trackCount;
    private long _totalSize;
    private bool _isScanning;

    private sealed record LibraryAlbum(string Title, string Artist, string Badge, string CoverClass);

    private static readonly List<LibraryAlbum> MockAlbums = new()
    {
        new("Prismatic Resonance", "Aural Architect", "24-bit/192kHz", "cover-prismatic"),
        new("Industrial Silence", "The Metric", "DSD256", "cover-industrial"),
        new("Void Geometry", "Null State", "FLAC 16/44.1", "cover-void"),
        new("Analog Circuits", "Voltage Control", "24-bit/96kHz", "cover-analog")
    };

    protected override async Task OnInitializedAsync()
    {
        AppState.Changed += OnStateChanged;
        Player.StateChanged += OnPlayerStateChanged;
        await LoadTracks();
    }

    private async Task LoadTracks()
    {
        _results = (await TrackRepo.SearchAsync(null, null, null, _searchQuery)).ToList();
        _trackCount = _results.Count;
        // Estimate size from bitrate & duration
        _totalSize = _results.Sum(t => (long)(t.BitRate > 0 && t.DurationMs > 0
            ? (double)t.BitRate * t.DurationMs / 8000.0
            : 0));
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _searchQuery = e.Value?.ToString();
        await PerformSearch();
    }

    private async Task ClearSearch()
    {
        _searchQuery = null;
        await PerformSearch();
    }

    private async Task PerformSearch()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery))
        {
            await LoadTracks();
        }
        else
        {
            _results = (await TrackRepo.SearchAsync(null, null, null, _searchQuery)).ToList();
        }
    }

    private void OnPlayerStateChanged(object? sender, EventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task PickAndScan()
    {
        try
        {
            var path = await JS.InvokeAsync<string?>("mediamusic.platform.pickFolder");
            if (string.IsNullOrEmpty(path)) return;

            _isScanning = true;
            var progress = new Progress<ScanProgress>(p =>
            {
                AppState.SetScanProgress(p);
                InvokeAsync(StateHasChanged);
            });
            await Library.ScanAsync(new[] { path }, progress);
            AppState.SetScanProgress(null);
            _isScanning = false;
            await LoadTracks();
        }
        catch
        {
            _isScanning = false;
        }
    }

    private void OnPlay(Track t) => Player.Play(t);

    private void PlayMockAlbum(LibraryAlbum album)
    {
        var track = new Track
        {
            Title = album.Title,
            ArtistName = album.Artist,
            AlbumTitle = album.Title,
            Format = album.Badge.Contains("FLAC") ? "FLAC" : (album.Badge.Contains("DSD") ? "DSF" : "WAV"),
            DurationMs = 240000,
            FilePath = "sample://library/" + album.Title
        };
        Player.Play(track);
    }

    private void ToggleFilter()
    {
        // Triggered filter action
    }

    private void ToggleSort()
    {
        // Triggered sort action
    }

    private async void OnStateChanged(object? sender, EventArgs e) => await InvokeAsync(StateHasChanged);

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        if (bytes < 1024L * 1024 * 1024 * 1024) return $"{bytes / (1024.0 * 1024 * 1024):F1} GB";
        return $"{bytes / (1024.0 * 1024 * 1024 * 1024):F1} TB";
    }

    public void Dispose()
    {
        AppState.Changed -= OnStateChanged;
        Player.StateChanged -= OnPlayerStateChanged;
    }
}

<style>
    .library-page {
        position: relative;
        width: 100%;
        height: 100%;
        overflow-y: auto;
        padding: 28px 36px 40px;
        background: #111318;
        color: #fff;
        user-select: none;
    }

    .library-page::-webkit-scrollbar { display: none; }
    .library-page { -ms-overflow-style: none; scrollbar-width: none; }

    /* ─── Header Section ─── */
    .library-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 28px;
    }

    .library-title {
        font-size: 28px;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: #ffffff;
    }

    .library-subtitle {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.45);
        margin-top: 4px;
        font-weight: 500;
    }

    .header-actions {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .search-box {
        position: relative;
        display: flex;
        align-items: center;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 9999px;
        padding: 0 16px;
        height: 36px;
        width: 220px;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .search-box:focus-within {
        border-color: rgba(168, 85, 247, 0.5);
        background: rgba(255, 255, 255, 0.04);
        width: 280px;
        box-shadow: 0 0 12px rgba(168, 85, 247, 0.1);
    }

    .search-icon {
        width: 14px;
        height: 14px;
        color: rgba(255, 255, 255, 0.4);
        margin-right: 8px;
        flex-shrink: 0;
        transition: color 0.2s;
    }

    .search-box:focus-within .search-icon {
        color: rgba(168, 85, 247, 0.8);
    }

    .search-input {
        background: transparent;
        border: none;
        outline: none;
        color: #ffffff;
        font-size: 12px;
        font-weight: 500;
        width: 100%;
        padding: 0;
    }

    .search-input::placeholder {
        color: rgba(255, 255, 255, 0.3);
    }

    .clear-btn {
        background: transparent;
        border: none;
        outline: none;
        padding: 0;
        margin-left: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255, 255, 255, 0.4);
        transition: color 0.2s;
        flex-shrink: 0;
    }

    .clear-btn:hover {
        color: #ffffff;
    }

    .clear-btn svg {
        width: 12px;
        height: 12px;
    }

    .search-empty-state {
        grid-column: 1 / -1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 20px;
        text-align: center;
    }

    .search-empty-state .empty-icon {
        width: 48px;
        height: 48px;
        color: rgba(255, 255, 255, 0.2);
        margin-bottom: 16px;
    }

    .search-empty-state .empty-title {
        font-size: 14px;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.7);
        margin-bottom: 6px;
    }

    .search-empty-state .empty-subtitle {
        font-size: 12px;
        color: rgba(255, 255, 255, 0.35);
    }

    .action-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 8px 18px;
        font-size: 12px;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.8);
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 9999px;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .action-btn:hover {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.3);
        color: #fff;
    }

    .action-icon {
        width: 14px;
        height: 14px;
    }

    /* ─── Import Zone ─── */
    .import-zone {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.02) 0%, rgba(255, 255, 255, 0.005) 100%);
        border: 1.5px dashed rgba(255, 255, 255, 0.12);
        border-radius: 16px;
        padding: 44px 24px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        margin-bottom: 40px;
    }

    .import-zone:hover {
        border-color: rgba(168, 85, 247, 0.45);
        background: rgba(168, 85, 247, 0.02);
        box-shadow: 0 0 24px rgba(168, 85, 247, 0.05);
    }

    .import-icon-circle {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.04);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        transition: transform 0.2s;
    }

    .import-zone:hover .import-icon-circle {
        transform: translateY(-2px);
        background: rgba(168, 85, 247, 0.1);
        border-color: rgba(168, 85, 247, 0.2);
    }

    .import-icon {
        width: 20px;
        height: 20px;
        color: rgba(255, 255, 255, 0.7);
    }

    .import-title {
        font-size: 16px;
        font-weight: 700;
        color: #ffffff;
        margin-bottom: 6px;
    }

    .import-subtitle {
        font-size: 12px;
        color: rgba(255, 255, 255, 0.35);
    }

    /* ─── Scan Progress ─── */
    .scan-progress-container {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 32px;
        padding: 0 4px;
    }

    .progress-bar-bg {
        flex-grow: 1;
        height: 4px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 99px;
        overflow: hidden;
    }

    .progress-bar-fill {
        height: 100%;
        background: linear-gradient(90deg, #c084fc 0%, #a855f7 100%);
        border-radius: 99px;
        transition: width 0.3s ease;
    }

    .progress-text {
        font-size: 11px;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.45);
        font-family: monospace;
    }

    /* ─── Recently Added Section ─── */
    .recently-added-section {
        display: flex;
        flex-direction: column;
    }

    .section-title-wrapper {
        margin-bottom: 20px;
    }

    .section-title {
        font-size: 13px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.45);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 8px;
    }

    .section-divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.08);
        width: 100%;
    }

    .album-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
    }

    @@media (max-width: 1024px) {
        .album-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .album-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .album-card {
        display: flex;
        flex-direction: column;
        cursor: pointer;
    }

    .album-cover-wrapper {
        position: relative;
        aspect-ratio: 1 / 1;
        border-radius: 10px;
        overflow: hidden;
        background: #181b22;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
        transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.25s;
    }

    .album-card:hover .album-cover-wrapper {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(168, 85, 247, 0.15);
    }

    .album-cover-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .album-cover-fallback {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .fallback-note-icon {
        width: 36px;
        height: 36px;
        color: rgba(255, 255, 255, 0.15);
    }

    .quality-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        font-size: 9px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.85);
        background: rgba(0, 0, 0, 0.35);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 4px;
        padding: 3px 6px;
        backdrop-filter: blur(12px);
        font-family: monospace;
        letter-spacing: 0.02em;
    }

    .play-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.35);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.2s ease;
    }

    .album-card:hover .play-overlay {
        opacity: 1;
    }

    .play-btn-circle {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: #a855f7;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 12px rgba(168, 85, 247, 0.4);
        transform: scale(0.9);
        transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .album-card:hover .play-btn-circle {
        transform: scale(1);
    }

    .album-title {
        margin-top: 12px;
        font-size: 13.5px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.95);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .album-artist {
        margin-top: 3px;
        font-size: 11.5px;
        color: rgba(255, 255, 255, 0.45);
        font-weight: 500;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .album-card:hover .album-title {
        color: #fff;
    }

    /* ─── Mock Cover Visuals ─── */
    .cover-prismatic {
        background: radial-gradient(circle at center, rgba(168, 85, 247, 0.3) 0%, #0d0d12 75%);
        position: relative;
    }
    .prism-shape {
        width: 32px;
        height: 52px;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.8) 0%, rgba(168, 85, 247, 0.5) 100%);
        clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
        z-index: 2;
    }
    .prism-glow {
        position: absolute;
        width: 50px;

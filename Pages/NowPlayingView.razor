@page "/nowplaying"
@inject PlayerService Player
@inject LyricsService Lyrics
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>正在播放 — MediaMusic</PageTitle>

@* ── Now Playing full page (Figma: 正在播放、歌词与频谱) ── *@
<div class="relative flex h-full overflow-hidden">
    @* Ambient background glow from album art *@
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full bg-accent/15 blur-[120px]"></div>
        <div class="absolute bottom-1/4 right-1/4 w-80 h-80 rounded-full bg-purple-500/10 blur-[100px]"></div>
    </div>

    @* ── Left Panel: Album art + metadata ── *@
    <div class="relative z-10 flex w-[45%] flex-col items-center justify-center p-10 gap-6">
        @* Album cover *@
        <div class="w-64 h-64 rounded-2xl bg-surface-variant overflow-hidden shadow-2xl shadow-accent/10">
            @if (!string.IsNullOrEmpty(Player.State.CurrentTrack?.CoverPath))
            {
                <img src="@Player.State.CurrentTrack.CoverPath" alt="Cover" class="w-full h-full object-cover" />
            }
            else
            {
                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-accent/20 to-purple-900/40">
                    <svg class="w-20 h-20 text-accent/40" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 3v10.55A4 4 0 1 0 14 17V7h4V3h-6z"/>
                    </svg>
                </div>
            }
        </div>

        @* Song metadata *@
        <div class="text-center space-y-1">
            <h1 class="text-2xl font-bold">@(Player.State.CurrentTrack?.Title ?? "未播放歌曲")</h1>
            <p class="text-on-surface/50">
                @(Player.State.CurrentTrack?.ArtistName ?? "无艺术家信息")
                @if (Player.State.CurrentTrack?.AlbumTitle is not null)
                {
                    <span> • @Player.State.CurrentTrack.AlbumTitle</span>
                }
            </p>
        </div>

        @* Quality badges *@
        <div class="flex gap-2">
            <span class="text-[10px] px-2 py-0.5 rounded-full bg-accent/10 text-accent font-medium tracking-wide">高解析度音频</span>
            @if (Player.State.CurrentTrack?.Format is not null)
            {
                <span class="text-[10px] px-2 py-0.5 rounded-full bg-surface-variant text-on-surface/50 font-mono">
                    @Player.State.CurrentTrack.Format.ToUpper() @(Player.State.CurrentTrack.SampleRate > 0 ? $"{Player.State.CurrentTrack.SampleRate / 1000}kHz" : "")
                </span>
            }
        </div>

        @* Audio visualizer wave *@
        <div class="flex items-end gap-[3px] h-8">
            @if (Player.State.IsPlaying)
            {
                @for (int i = 0; i < 32; i++)
                {
                    var h = 4 + Random.Shared.Next(24);
                    var d = i * 0.05;
                    <div class="w-[3px] rounded-full bg-accent/60"
                         style="height: @(h)px; animation: eq-wave @(0.5 + d)s ease-in-out infinite alternate; animation-delay: @(d)s;"></div>
                }
            }
            else
            {
                @for (int i = 0; i < 32; i++)
                {
                    <div class="w-[3px] h-1 rounded-full bg-on-surface/10"></div>
                }
            }
        </div>
    </div>

    @* ── Right Panel: Lyrics ── *@
    <div class="relative z-10 flex-1 flex flex-col px-12 py-10 overflow-hidden">
        <div class="lyrics-container flex-1 overflow-y-auto flex flex-col gap-6 scrollbar-hide py-[45vh]">
            @if (Lyrics.Lines.Count == 0)
            {
                <div class="my-auto space-y-3 text-center">
                    <p class="text-2xl text-on-surface/15 font-light italic">暂无歌词</p>
                    <p class="text-sm text-on-surface/20">同名 .lrc 文件将自动匹配</p>
                </div>
            }
            else
            {
                @foreach (var line in Lyrics.Lines)
                {
                    var isActive = Lyrics.IsActive(line);
                    <p class="lyric-line transition-all duration-500 @(isActive
                        ? "lyric-line-active text-2xl font-bold text-accent"
                        : "text-lg text-on-surface/30 font-light") text-center">
                        @line.Text
                    </p>
                }
            }
        </div>
    </div>
</div>

@code {
    private int _lastActiveIndex = -1;
    private string? _loadedFilePath;

    protected override void OnInitialized()
    {
        Player.StateChanged += OnPlayerStateChanged;
        UpdateLyrics();
    }

    private async void OnPlayerStateChanged(object? sender, EventArgs e)
    {
        var trackChanged = UpdateLyrics();
        await InvokeAsync(StateHasChanged);

        var activeIdx = Lyrics.GetActiveIndex(TimeSpan.FromMilliseconds(Player.State.PositionMs));
        if (activeIdx != _lastActiveIndex || trackChanged)
        {
            _lastActiveIndex = activeIdx;
            // Introduce a tiny delay so Blazor has time to render the updated DOM before JS runs
            await Task.Delay(50);
            await JS.InvokeVoidAsync("mediamusic.lyrics.scrollToActive");
        }
    }

    private bool UpdateLyrics()
    {
        var currentTrack = Player.State.CurrentTrack;
        if (currentTrack != null)
        {
            if (_loadedFilePath != currentTrack.FilePath)
            {
                _loadedFilePath = currentTrack.FilePath;
                Lyrics.LoadForTrack(currentTrack.FilePath);
                _lastActiveIndex = -1;
                return true;
            }
        }
        else
        {
            if (_loadedFilePath != null)
            {
                _loadedFilePath = null;
                Lyrics.LoadForTrack(string.Empty);
                _lastActiveIndex = -1;
                return true;
            }
        }
        return false;
    }

    public void Dispose()
    {
        Player.StateChanged -= OnPlayerStateChanged;
    }
}

<style>
    @@keyframes eq-wave {
        0%   { height: 4px; }
        100% { height: 28px; }
    }
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    
    .lyrics-container {
        scroll-behavior: smooth;
    }
    
    .lyric-line {
        transition: all 0.3s ease;
    }
</style>

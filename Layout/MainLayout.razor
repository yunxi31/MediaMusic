@using MediaMusic.Layout
@inherits LayoutComponentBase
@inject AppState AppState
@inject SettingsService Settings
@inject ThemeService Theme
@inject NavigationManager Nav
@inject IJSRuntime JS

@* Full application shell: TitleBar → Sidebar + Content + PlayerBar *@
<div class="flex h-full flex-col bg-background text-on-surface">
    @if (AppState.IsOnboardingComplete)
    {
        @* ── Post-onboarding: sidebar + content + player bar ── *@
        <div class="flex flex-1 overflow-hidden">
            <Sidebar />
            <main class="flex-1 overflow-hidden bg-background">
                @Body
            </main>
        </div>
        <PlayerControls />
    }
    else
    {
        @* ── Onboarding: truly full-bleed ── *@
        <div class="relative flex-1 overflow-hidden">
            <main class="h-full w-full">
                @Body
            </main>
        </div>
    }
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        // Restore theme preference using the component-level IJSRuntime (always live).
        // ThemeService is Scoped but may capture a different JSRuntime instance;
        // using the component-injected JS guarantees we reach the correct WebView.
        var theme = await Settings.GetAsync<string>("theme", "dark");
        if (theme != null)
        {
            try
            {
                var jsClass = theme == "dark" ? "add" : "remove";
                await JS.InvokeVoidAsync("eval", $"document.documentElement.classList.{jsClass}('dark')");
            }
            catch { }
            AppState.SetTheme(theme);
        }

        // Hydrate onboarding state from DB on first load.
        var doneVal = await Settings.GetAsync<string>("onboarding_complete", "false");
        var done = doneVal == "true";
        if (done && !AppState.IsOnboardingComplete)
        {
            AppState.SetOnboardingComplete(true);
        }
        else if (!done)
        {
            // Force navigate to onboarding if not completed.
            var uri = Nav.ToBaseRelativePath(Nav.Uri);
            if (!uri.StartsWith("onboarding", StringComparison.OrdinalIgnoreCase))
            {
                Nav.NavigateTo("/onboarding");
            }
        }

        AppState.Changed += OnStateChanged;
    }

    private async void OnStateChanged(object? sender, EventArgs e)
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AppState.Changed -= OnStateChanged;
    }
}
